---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSchema from '../components/FAQSchema.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import CategoryIcon from '../components/CategoryIcon';

const title = "Salary to Hourly Calculator | Wage Converter";
const description = "Convert annual, monthly, or weekly salaries into equivalent hourly rates, daily earnings, and weekly payouts.";

const crumbs = [
  { name: "Home", url: "/" },
  { name: "Finance & Business", url: "/finance-business" },
  { name: "Salary to Hourly Calculator", url: "/salary-to-hourly-calculator" }
];

const faqs = [
  {
    question: "How do you calculate salary to hourly?",
    answer: "To convert annual salary to an hourly wage rate: divide the annual salary by the number of work weeks (typically 52), then divide that result by the number of hours worked per week (typically 40). Formula: Hourly Rate = Annual Salary / (Weeks/Year × Hours/Week)."
  },
  {
    question: "How many work hours are in a year?",
    answer: "For a full-time employee working 40 hours per week for 52 weeks, there are exactly 2,080 work hours in a year. For a 35-hour work week, there are 1,820 work hours."
  }
];
---

<BaseLayout
  title={title}
  description={description}
  keywords="salary to hourly calculator, salary converter, salary to hourly, wage calculator, hourly rate calculator"
  canonicalPath="/salary-to-hourly-calculator"
>
  <BreadcrumbSchema crumbs={crumbs} />

  <!-- Title & Featured Snippet Bait -->
  <section class="mb-8 select-none">
    <h1 class="text-3xl font-extrabold tracking-tight text-ink mb-3 flex items-center gap-2">
      <CategoryIcon id="finance" className="w-8 h-8 text-brand-blue" />
      <span>Salary to Hourly Calculator</span>
    </h1>

    <!-- Direct Answer Block -->
    <div class="direct-answer bg-card border border-hairline rounded-xl p-5 mb-5 shadow-sm max-w-2xl">
      <p class="text-base text-ink mb-1">
        <strong>Hourly Rate = Annual Salary ÷ 2,080 Hours</strong>
      </p>
      <p class="text-xs text-body-text font-normal leading-relaxed">
        Example: An annual salary of $52,000 translates to exactly $25.00 per hour (based on a standard 40-hour work week and 52 weeks a year).
      </p>
    </div>

    <p class="text-sm text-body-text max-w-2xl leading-relaxed">
      Convert yearly salary into hourly pay scales. Customize your average work week hours and holiday details below to calculate precise daily, weekly, and monthly rates.
    </p>
  </section>

  <!-- Interactive Scaler Widget -->
  <section class="mb-10 max-w-2xl bg-card border border-hairline rounded-2xl p-6 transition-colors">
    <h2 class="text-sm font-bold uppercase tracking-wider text-muted-text mb-6 font-mono font-bold">Interactive Salary Converter</h2>

    <div class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="sm:col-span-1">
          <label for="salary-input" class="block text-xs font-mono font-bold text-muted-text uppercase mb-1.5">Annual Salary ($)</label>
          <input
            id="salary-input"
            type="number"
            value="52000"
            min="0"
            class="w-full bg-canvas border border-hairline text-ink rounded-lg p-3 text-lg font-mono font-bold focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue transition-all"
          />
        </div>
        <div class="sm:col-span-1">
          <label for="hours-input" class="block text-xs font-mono font-bold text-muted-text uppercase mb-1.5">Hours Per Week</label>
          <input
            id="hours-input"
            type="number"
            value="40"
            min="1"
            max="168"
            class="w-full bg-canvas border border-hairline text-ink rounded-lg p-3 text-lg font-mono font-bold focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue transition-all"
          />
        </div>
        <div class="sm:col-span-1">
          <label for="weeks-input" class="block text-xs font-mono font-bold text-muted-text uppercase mb-1.5">Weeks Per Year</label>
          <input
            id="weeks-input"
            type="number"
            value="52"
            min="1"
            max="52"
            class="w-full bg-canvas border border-hairline text-ink rounded-lg p-3 text-lg font-mono font-bold focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue transition-all"
          />
        </div>
      </div>

      <div class="pt-4 border-t border-hairline">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="p-3 bg-canvas border border-hairline rounded-lg text-center">
            <span class="block text-[10px] font-bold text-muted-text uppercase font-mono">Hourly</span>
            <span id="rate-hourly" class="text-lg font-mono font-bold text-brand-blue">$25.00</span>
          </div>
          <div class="p-3 bg-canvas border border-hairline rounded-lg text-center">
            <span class="block text-[10px] font-bold text-muted-text uppercase font-mono">Daily (8h)</span>
            <span id="rate-daily" class="text-lg font-mono font-bold text-ink">$200.00</span>
          </div>
          <div class="p-3 bg-canvas border border-hairline rounded-lg text-center">
            <span class="block text-[10px] font-bold text-muted-text uppercase font-mono">Weekly</span>
            <span id="rate-weekly" class="text-lg font-mono font-bold text-ink">$1,000.00</span>
          </div>
          <div class="p-3 bg-canvas border border-hairline rounded-lg text-center">
            <span class="block text-[10px] font-bold text-muted-text uppercase font-mono">Monthly</span>
            <span id="rate-monthly" class="text-lg font-mono font-bold text-ink">$4,333.33</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Formula Details & Reference Table -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 border-t border-hairline pt-8 mb-10 text-xs text-body-text max-w-4xl">
    <section>
      <h3 class="font-bold text-ink uppercase tracking-wider text-[10px] font-mono mb-2">Wage Conversion Logic</h3>
      <p class="leading-relaxed mb-3">
        Converting your pay rate across scales uses these standard steps (assuming standard 40h/week and 52 weeks/year):
      </p>
      <ul class="list-disc pl-4 space-y-1">
        <li><strong>Weekly Wage:</strong> Annual Salary / Weeks per Year.</li>
        <li><strong>Monthly Wage:</strong> Annual Salary / 12 Months.</li>
        <li><strong>Daily Wage:</strong> Weekly Wage / 5 Days (or Hourly × 8 Hours).</li>
        <li><strong>Hourly Wage:</strong> Weekly Wage / Hours per Week.</li>
      </ul>
    </section>

    <section>
      <h3 class="font-bold text-ink uppercase tracking-wider text-[10px] font-mono mb-2">Salary to Hourly Chart (40h/week)</h3>
      <table class="w-full text-left font-mono text-[10px] border border-hairline border-collapse mt-2">
        <thead>
          <tr class="bg-card border-b border-hairline text-muted-text">
            <th class="p-1.5 border-r border-hairline">Annual Salary</th>
            <th class="p-1.5 border-r border-hairline">Weekly Rate</th>
            <th class="p-1.5 border-r border-hairline">Monthly Rate</th>
            <th class="p-1.5">Hourly Rate</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-hairline">
          <tr>
            <td class="p-1.5 border-r border-hairline">$30,000</td>
            <td class="p-1.5 border-r border-hairline">$576.92</td>
            <td class="p-1.5 border-r border-hairline">$2,500.00</td>
            <td class="p-1.5">$14.42</td>
          </tr>
          <tr>
            <td class="p-1.5 border-r border-hairline">$45,000</td>
            <td class="p-1.5 border-r border-hairline">$865.38</td>
            <td class="p-1.5 border-r border-hairline">$3,750.00</td>
            <td class="p-1.5">$21.63</td>
          </tr>
          <tr>
            <td class="p-1.5 border-r border-hairline">$60,000</td>
            <td class="p-1.5 border-r border-hairline">$1,153.85</td>
            <td class="p-1.5 border-r border-hairline">$5,000.00</td>
            <td class="p-1.5">$28.85</td>
          </tr>
          <tr>
            <td class="p-1.5 border-r border-hairline">$100,000</td>
            <td class="p-1.5 border-r border-hairline">$1,923.08</td>
            <td class="p-1.5 border-r border-hairline">$8,333.33</td>
            <td class="p-1.5">$48.08</td>
          </tr>
        </tbody>
      </table>
    </section>
  </div>

  <!-- Related Sibling Tools Navigation -->
  <section class="border-t border-hairline pt-6 mb-10 text-xs text-body-text max-w-4xl select-none">
    <h3 class="font-semibold text-ink mb-3">Related Finance Tools</h3>
    <div class="flex flex-wrap gap-3 font-mono">
      <a href="/simple-interest-calculator" class="px-2.5 py-1.5 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded transition-colors">Simple Interest Calculator</a>
      <a href="/compound-interest-calculator" class="px-2.5 py-1.5 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded transition-colors">Compound Interest Calculator</a>
      <a href="/sales-tax-calculator" class="px-2.5 py-1.5 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded transition-colors">Sales Tax Calculator</a>
      <a href="/discount-calculator" class="px-2.5 py-1.5 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded transition-colors">Discount Calculator</a>
    </div>
  </section>

  <!-- FAQs Section -->
  <section class="bg-card border border-hairline rounded-xl p-6 mb-10 max-w-4xl transition-colors select-none">
    <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-4 font-mono">Frequently Asked Questions</h2>
    <FAQSchema faqs={faqs} />
  </section>

  <script>
    const salaryInput = document.getElementById('salary-input') as HTMLInputElement;
    const hoursInput = document.getElementById('hours-input') as HTMLInputElement;
    const weeksInput = document.getElementById('weeks-input') as HTMLInputElement;
    
    const rateHourly = document.getElementById('rate-hourly') as HTMLSpanElement;
    const rateDaily = document.getElementById('rate-daily') as HTMLSpanElement;
    const rateWeekly = document.getElementById('rate-weekly') as HTMLSpanElement;
    const rateMonthly = document.getElementById('rate-monthly') as HTMLSpanElement;

    function calculate() {
      const salary = parseFloat(salaryInput.value) || 0;
      const hours = parseFloat(hoursInput.value) || 40;
      const weeks = parseFloat(weeksInput.value) || 52;

      const hourly = salary / (weeks * hours);
      const daily = hourly * (hours / 5); // Assumes 5-day week
      const weekly = salary / weeks;
      const monthly = salary / 12;

      if (rateHourly) rateHourly.textContent = `$${hourly.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
      if (rateDaily) rateDaily.textContent = `$${daily.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
      if (rateWeekly) rateWeekly.textContent = `$${weekly.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
      if (rateMonthly) rateMonthly.textContent = `$${monthly.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    }

    salaryInput?.addEventListener('input', calculate);
    hoursInput?.addEventListener('input', calculate);
    weeksInput?.addEventListener('input', calculate);
  </script>
</BaseLayout>
