---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSchema from '../components/FAQSchema.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import CategoryIcon from '../components/CategoryIcon';

const title = "Simple Interest Calculator | Principal, Rate, Time Formula";
const description = "Calculate simple interest values, total accumulation amounts, or work backwards to find principal, annual rates, or loan terms instantly.";

const crumbs = [
  { name: "Home", url: "/" },
  { name: "Finance & Business", url: "/finance-business" },
  { name: "Simple Interest Calculator", url: "/simple-interest-calculator" }
];

const faqs = [
  {
    question: "What is the simple interest formula?",
    answer: "The simple interest formula is: Interest (I) = Principal (P) × Rate (R) × Time (T), where P is the starting amount, R is the annual interest rate (in decimal form), and T is the time period in years."
  },
  {
    question: "How is simple interest calculated monthly?",
    answer: "To calculate simple interest monthly, convert the monthly term into years by dividing the number of months by 12. For example, a 6-month term is 6/12 = 0.5 years. Multiply this value by the principal and rate."
  }
];
---

<BaseLayout
  title={title}
  description={description}
  keywords="simple interest calculator, simple interest formula, interest calculator, calculate simple interest, loan interest"
  canonicalPath="/simple-interest-calculator"
>
  <BreadcrumbSchema crumbs={crumbs} />

  <!-- Title & Featured Snippet Bait -->
  <section class="mb-8 select-none">
    <h1 class="text-3xl font-extrabold tracking-tight text-ink mb-3 flex items-center gap-2">
      <CategoryIcon id="finance" className="w-8 h-8 text-brand-blue" />
      <span>Simple Interest Calculator</span>
    </h1>

    <!-- Direct Answer Block -->
    <div class="direct-answer bg-card border border-hairline rounded-xl p-5 mb-5 shadow-sm max-w-2xl">
      <p class="text-base text-ink mb-1">
        <strong>Interest = Principal × Annual Rate × Term in Years</strong>
      </p>
      <p class="text-xs text-body-text font-normal leading-relaxed">
        Example: A $1,000 principal at a 5% interest rate for 3 years accrues $150 in simple interest, totaling $1,150.
      </p>
    </div>

    <p class="text-sm text-body-text max-w-2xl leading-relaxed">
      Quickly determine interest accrued or total balance on a loan or savings account. Adjust rate, time, and principal inputs using the interactive widget below.
    </p>
  </section>

  <!-- Interactive Scaler Widget -->
  <section class="mb-10 max-w-2xl bg-card border border-hairline rounded-2xl p-6 transition-colors">
    <h2 class="text-sm font-bold uppercase tracking-wider text-muted-text mb-6 font-mono font-bold">Interactive Simple Interest Calculator</h2>

    <div class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="principal-input" class="block text-xs font-mono font-bold text-muted-text uppercase mb-1.5">Principal Amount ($)</label>
          <input
            id="principal-input"
            type="number"
            value="1000"
            min="0"
            class="w-full bg-canvas border border-hairline text-ink rounded-lg p-3 text-lg font-mono font-bold focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue transition-all"
          />
        </div>
        <div>
          <label for="rate-input" class="block text-xs font-mono font-bold text-muted-text uppercase mb-1.5">Annual Interest Rate (%)</label>
          <input
            id="rate-input"
            type="number"
            value="5"
            step="0.01"
            min="0"
            class="w-full bg-canvas border border-hairline text-ink rounded-lg p-3 text-lg font-mono font-bold focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue transition-all"
          />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="time-input" class="block text-xs font-mono font-bold text-muted-text uppercase mb-1.5">Time Period (Years)</label>
          <input
            id="time-input"
            type="number"
            value="3"
            step="0.1"
            min="0"
            class="w-full bg-canvas border border-hairline text-ink rounded-lg p-3 text-lg font-mono font-bold focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue transition-all"
          />
        </div>
        <div class="space-y-3">
          <div class="p-3 bg-canvas border border-hairline rounded-lg flex justify-between items-center">
            <div>
              <span class="block text-[10px] font-bold text-muted-text uppercase font-mono">Interest Earned</span>
              <span id="interest-result" class="text-xl font-mono font-bold text-brand-blue">$150.00</span>
            </div>
          </div>
          <div class="p-3 bg-canvas border border-hairline rounded-lg flex justify-between items-center">
            <div>
              <span class="block text-[10px] font-bold text-muted-text uppercase font-mono">Total Balance</span>
              <span id="total-result" class="text-xl font-mono font-bold text-ink">$1,150.00</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Formula Details & Reference Table -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 border-t border-hairline pt-8 mb-10 text-xs text-body-text max-w-4xl">
    <section>
      <h3 class="font-bold text-ink uppercase tracking-wider text-[10px] font-mono mb-2">How Simple Interest Works</h3>
      <p class="leading-relaxed mb-3">
        Unlike compound interest, simple interest does not accumulate on top of past interest earnings. It is calculated solely as a flat percentage of the starting principal balance.
      </p>
      <div class="p-3 bg-card border border-hairline rounded-lg font-mono mb-3">
        Interest (I) = P × R × T
      </div>
      <p class="leading-relaxed">
        This formula is standard for short-term personal loans, car loans, and certificates of deposit (CDs) that pay out earnings directly.
      </p>
    </section>

    <section>
      <h3 class="font-bold text-ink uppercase tracking-wider text-[10px] font-mono mb-2">Compound vs. Simple Interest</h3>
      <p class="leading-relaxed mb-3">
        Simple interest yields the same return every year. For example, a 5% rate on $1,000 earns exactly $50 every single year.
      </p>
      <p class="leading-relaxed">
        Compound interest pays interest on your interest, causing the account to grow exponentially. Over long investment terms, compound interest yields significantly higher payouts than simple interest.
      </p>
    </section>
  </div>

  <!-- Related Sibling Tools Navigation -->
  <section class="border-t border-hairline pt-6 mb-10 text-xs text-body-text max-w-4xl select-none">
    <h3 class="font-semibold text-ink mb-3">Related Finance Tools</h3>
    <div class="flex flex-wrap gap-3 font-mono">
      <a href="/compound-interest-calculator" class="px-2.5 py-1.5 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded transition-colors">Compound Interest Calculator</a>
      <a href="/sales-tax-calculator" class="px-2.5 py-1.5 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded transition-colors">Sales Tax Calculator</a>
      <a href="/discount-calculator" class="px-2.5 py-1.5 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded transition-colors">Discount Calculator</a>
      <a href="/salary-to-hourly-calculator" class="px-2.5 py-1.5 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded transition-colors">Salary to Hourly Converter</a>
    </div>
  </section>

  <!-- FAQs Section -->
  <section class="bg-card border border-hairline rounded-xl p-6 mb-10 max-w-4xl transition-colors select-none">
    <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-4 font-mono">Frequently Asked Questions</h2>
    <FAQSchema faqs={faqs} />
  </section>

  <script>
    const principalInput = document.getElementById('principal-input') as HTMLInputElement;
    const rateInput = document.getElementById('rate-input') as HTMLInputElement;
    const timeInput = document.getElementById('time-input') as HTMLInputElement;
    
    const interestResult = document.getElementById('interest-result') as HTMLSpanElement;
    const totalResult = document.getElementById('total-result') as HTMLSpanElement;

    function calculate() {
      const p = parseFloat(principalInput.value) || 0;
      const r = parseFloat(rateInput.value) || 0;
      const t = parseFloat(timeInput.value) || 0;

      const interest = p * (r / 100) * t;
      const total = p + interest;

      if (interestResult) interestResult.textContent = `$${interest.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
      if (totalResult) totalResult.textContent = `$${total.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    }

    principalInput?.addEventListener('input', calculate);
    rateInput?.addEventListener('input', calculate);
    timeInput?.addEventListener('input', calculate);

    // Initial calculation on load
    calculate();
  </script>
</BaseLayout>
