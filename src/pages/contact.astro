---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us — myunitconverter.app"
  description="Contact the creators of myunitconverter.app for support, feature requests, or queries."
>
  <div class="max-w-2xl mx-auto mt-12 mb-16 select-none">
    <h1 class="text-3xl font-extrabold tracking-tight text-ink mb-6">Contact Us</h1>
    
    <div class="bg-card border border-hairline rounded-xl p-6 shadow-[0_2px_8px_rgba(0,0,0,0.02)]">
      <form class="flex flex-col gap-4" onsubmit="event.preventDefault(); alert('Thank you! Your message has been received.'); this.reset();">
        <div class="flex flex-col gap-1.5">
          <label for="name" class="text-xs font-semibold text-body-text">Name</label>
          <input
            type="text"
            id="name"
            required
            placeholder="John Doe"
            class="w-full px-3 py-2 border border-hairline bg-canvas rounded-lg text-sm text-ink focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue transition-all"
          />
        </div>
        
        <div class="flex flex-col gap-1.5">
          <label for="email" class="text-xs font-semibold text-body-text">Email Address</label>
          <input
            type="email"
            id="email"
            required
            placeholder="john@example.com"
            class="w-full px-3 py-2 border border-hairline bg-canvas rounded-lg text-sm text-ink focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue transition-all"
          />
        </div>
        
        <div class="flex flex-col gap-1.5">
          <label for="message" class="text-xs font-semibold text-body-text">Message</label>
          <textarea
            id="message"
            required
            rows="5"
            placeholder="Write your suggestions, questions, or bugs here..."
            class="w-full px-3 py-2 border border-hairline bg-canvas rounded-lg text-sm text-ink focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue transition-all resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full md:w-auto md:self-end px-5 py-2.5 bg-brand-ink text-white dark:bg-white dark:text-black hover:opacity-90 font-medium text-sm rounded-lg cursor-pointer transition-opacity flex items-center justify-center gap-1.5 shadow-[0_1px_2px_rgba(0,0,0,0.05)]"
        >
          Send Message
        </button>
      </form>
    </div>
  </div>
</BaseLayout>
