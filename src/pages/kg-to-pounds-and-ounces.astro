---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdBanner from '../components/AdBanner.astro';

const title = "kg to Pounds and Ounces Converter | Weight Calculator";
const description = "Convert kilograms (kg) to pounds (lbs) and ounces (oz) instantly. Perfect for tracking infant weights and culinary recipes.";

const commonMetricWeights = [
  { kg: 2.5, lbs: 5, oz: 8 },
  { kg: 3.0, lbs: 6, oz: 10 },
  { kg: 3.5, lbs: 7, oz: 11 },
  { kg: 4.0, lbs: 8, oz: 13 },
  { kg: 4.5, lbs: 9, oz: 15 },
  { kg: 5.0, lbs: 11, oz: 0 }
];
---

<BaseLayout title={title} description={description} categorySlug="weight">
  <nav class="flex text-[10px] font-mono text-muted-text mt-6 mb-4 gap-1.5 items-center select-none" aria-label="Breadcrumb">
    <a href="/" class="hover:text-brand-blue transition-colors">Home</a>
    <span>/</span>
    <a href="/weight-converter" class="hover:text-brand-blue transition-colors">Weight Converter</a>
    <span>/</span>
    <span class="text-ink font-semibold">kg to Pounds & Ounces</span>
  </nav>

  <AdBanner slot="kg-to-lbs-oz-top" format="horizontal" />

  <section class="mb-8">
    <h1 class="text-3xl font-extrabold tracking-tight text-ink mb-3">kg to Pounds and Ounces Converter</h1>
    
    <!-- Direct Answer Block -->
    <div class="direct-answer bg-card border border-hairline rounded-xl p-5 mb-5 shadow-sm max-w-2xl">
      <p class="text-base text-ink mb-1">
        <strong>3.5 kg = 7 pounds 11 ounces (approx)</strong>
      </p>
      <p class="text-xs text-body-text font-normal leading-relaxed">
        Formula: Total Pounds = kg ÷ 0.453592. Pounds = floor(Pounds). Remaining Ounces = (Pounds - floor) × 16.
      </p>
    </div>
  </section>

  <!-- Interactive Form -->
  <section class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
    <div class="bg-card border border-hairline rounded-2xl p-6 space-y-4">
      <h2 class="text-sm font-bold uppercase tracking-wider text-muted-text mb-4 font-mono font-bold">Input Kilograms</h2>
      
      <div>
        <label for="kg-in" class="block text-xs font-mono text-muted-text mb-1">Weight (kg)</label>
        <input id="kg-in" type="number" value="3.5" class="w-full bg-canvas border border-hairline text-ink rounded-lg p-3 text-lg font-mono font-bold focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue transition-all" />
      </div>
    </div>

    <!-- Outputs -->
    <div class="bg-card border border-hairline rounded-2xl p-6 space-y-4">
      <h2 class="text-sm font-bold uppercase tracking-wider text-muted-text mb-4 font-mono font-bold font-bold text-muted-text font-mono">Imperial Weight Equivalent</h2>
      
      <div class="p-4 bg-canvas border border-hairline rounded-lg">
        <span class="block text-[10px] font-bold text-muted-text uppercase font-mono">Calculated Weight</span>
        <span id="weight-res" class="text-2xl font-mono font-bold text-brand-blue">7 lb 11.5 oz</span>
        <span id="lbs-decimal-res" class="text-xs font-mono text-muted-text ml-2">(7.72 lbs)</span>
      </div>
    </div>
  </section>

  <AdBanner slot="kg-to-lbs-oz-mid" format="rectangle" />

  <!-- Reference Chart Matrix Table -->
  <section class="mb-10 max-w-4xl">
    <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-4 font-mono font-bold">Metric Weight to Imperial lookup</h2>
    
    <AdBanner slot="kg-to-lbs-oz-table" format="horizontal" />

    <div class="overflow-hidden border border-hairline rounded-xl">
      <table class="w-full border-collapse text-left text-xs font-mono">
        <thead>
          <tr class="bg-card border-b border-hairline text-muted-text text-[10px] uppercase font-mono">
            <th class="p-3 font-semibold">Kilograms</th>
            <th class="p-3 font-semibold">Imperial Equivalent</th>
            <th class="p-3 font-semibold">Total Pounds</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-hairline">
          {commonMetricWeights.map(row => (
            <tr class="hover:bg-card/40 transition-colors">
              <td class="p-3 font-bold text-brand-blue">{row.kg} kg</td>
              <td class="p-3 text-ink">
                {row.lbs >= 5 && row.lbs <= 10 && row.oz % 4 === 0 ? (
                  <a href={`/${row.lbs}-lbs-${row.oz}-ounces-to-kg`} class="text-brand-blue hover:underline font-bold">
                    {row.lbs} lb {row.oz} oz
                  </a>
                ) : (
                  <span>{row.lbs} lb {row.oz} oz</span>
                )}
              </td>
              <td class="p-3 text-muted-text">{(row.kg/0.45359237).toFixed(2)} lbs</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <script>
    const kgIn = document.getElementById('kg-in') as HTMLInputElement;
    const weightRes = document.getElementById('weight-res') as HTMLSpanElement;
    const lbsDecimalRes = document.getElementById('lbs-decimal-res') as HTMLSpanElement;

    function calculate() {
      const kg = parseFloat(kgIn.value) || 0;

      const totalLbs = kg / 0.45359237;
      const lbs = Math.floor(totalLbs);
      const oz = Math.round((totalLbs - lbs) * 16 * 10) / 10;

      // Handle overflow rounding (e.g. 5 lb 16 oz -> 6 lb 0 oz)
      let adjLbs = lbs;
      let adjOz = oz;
      if (adjOz >= 16) {
        adjLbs += 1;
        adjOz -= 16;
      }

      if (weightRes) weightRes.textContent = `${adjLbs} lb ${adjOz.toFixed(0 === adjOz % 1 ? 0 : 1)} oz`;
      if (lbsDecimalRes) lbsDecimalRes.textContent = `(${totalLbs.toFixed(2)} lbs)`;
    }

    kgIn?.addEventListener('input', calculate);
  </script>

  <AdBanner slot="kg-to-lbs-oz-bottom" format="horizontal" />
</BaseLayout>
