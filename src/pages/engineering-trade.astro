---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryIcon from '../components/CategoryIcon';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import FAQSchema from '../components/FAQSchema.astro';

const title = "Engineering & Trade Calculators — Wire Gauge, Torque, Pipe Size";
const description = "Free online engineering and trade calculators. Convert AWG to mm², check bolt torque specifications, convert pipe sizes, calculate steel weights, and hardness ratings.";

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Engineering & Trade', url: '/engineering-trade' }
];

const tools = [
  { label: "AWG Wire to mm²", href: "/awg-to-mm2-wire-gauge-calculator", desc: "Convert American Wire Gauge (AWG) wire sizes to cross-sectional area in square millimeters (mm²)." },
  { label: "mm² to AWG Wire", href: "/mm2-to-awg-calculator", desc: "Convert wire cross-sectional areas from square millimeters (mm²) to American Wire Gauge (AWG)." },
  { label: "Torque ft-lb to Nm", href: "/torque-converter-ft-lb-to-nm", desc: "Convert torque values between foot-pounds (ft-lb) and Newton-meters (Nm) instantly." },
  { label: "Bolt Torque Specs", href: "/bolt-torque-spec-calculator", desc: "Look up tight bolt tension and torque limits for standard steel grade fasteners." },
  { label: "Pipe Size Nom/Actual", href: "/pipe-size-converter-nominal-to-actual", desc: "Convert nominal pipe sizes (NPS) to actual outside diameter (OD) and wall thickness ratings." },
  { label: "Hardness Converter", href: "/hardness-converter-rockwell-brinell-vickers", desc: "Convert metal hardness measurements across Rockwell, Brinell, Vickers, and Shore scales." },
  { label: "Steel Weight Calc", href: "/steel-weight-calculator-kg-per-meter", desc: "Calculate weight rates per meter for steel bars, sheets, pipes, and beams." },
  { label: "Thread Pitch Metric/UN", href: "/thread-pitch-converter-metric-unc-unf", desc: "Convert thread pitch between metric measurements and imperial Unified (UNC/UNF) threads." },
  { label: "PSI/Bar/kPa Converter", href: "/psi-to-bar-to-kpa-converter", desc: "Convert pressure units between PSI, Bar, Kilopascals (kPa), and atmospheres." },
  { label: "Flow gpm to lpm", href: "/flow-rate-converter-gpm-to-lpm", desc: "Convert liquid flow rates between US Gallons Per Minute (GPM) and Liters Per Minute (LPM)." }
];

const faqs = [
  {
    question: "What is AWG and why is it used?",
    answer: "AWG stands for American Wire Gauge, which is a standardized system for specifying the diameter of round, solid, nonferrous, electrically conducting wire. Larger AWG numbers represent smaller wire diameters, while smaller AWG numbers (including 0, 2/0, etc.) indicate thicker wire."
  },
  {
    question: "How do I convert foot-pounds (ft-lb) to Newton-meters (Nm)?",
    answer: "To convert foot-pounds to Newton-meters, multiply the torque value by 1.355818. To convert Newton-meters to foot-pounds, multiply the torque value by 0.737562."
  },
  {
    question: "Why does the actual diameter of a pipe differ from its nominal size?",
    answer: "Nominal Pipe Size (NPS) is a set of standard sizes for high or low pressure and temperatures. For pipes smaller than 14 inches, the NPS designation does not match the actual outside diameter; instead, it represents a generic design size. For pipes 14 inches and larger, the NPS is equal to the actual outside diameter."
  }
];
---

<BaseLayout
  title={title}
  description={description}
  keywords="engineering calculators, awg to mm2, torque converter, bolt torque specs, pipe size chart, metal hardness converter, steel weight calculator"
  canonicalPath="/engineering-trade"
  ogTitle={title}
  ogDescription={description}
>
  <BreadcrumbSchema crumbs={crumbs} />

  <!-- Title Section -->
  <section class="mb-8 select-none">
    <h1 class="text-3xl font-extrabold tracking-tight text-ink mb-2 flex items-center gap-2.5">
      <CategoryIcon id="torque" className="w-8 h-8 text-brand-blue" />
      <span>Engineering & Trade Calculators</span>
    </h1>
    <p class="text-sm text-body-text max-w-2xl leading-relaxed">
      Professional trade calculators for wire gauges, bolt torque limits, pipe dimensions, pressure ratings, and steel beam/plate weight estimations.
    </p>
  </section>

  <!-- Tools Grid -->
  <section class="mb-10 select-none">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tools.map(tool => (
        <a
          href={tool.href}
          class="group block p-5 rounded-xl border border-hairline bg-card hover:border-brand-blue transition-all duration-200 hover:shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex flex-col justify-between cursor-pointer"
        >
          <div>
            <h2 class="font-semibold text-sm text-ink mb-2 group-hover:text-brand-blue transition-colors duration-200">
              {tool.label}
            </h2>
            <p class="text-xs text-body-text mb-4 leading-relaxed line-clamp-3">
              {tool.desc}
            </p>
          </div>
          <span
            class="inline-flex items-center text-[10px] font-semibold text-brand-blue opacity-80 group-hover:opacity-100 transition-opacity mt-auto pt-2"
          >
            Open calculator
            <svg class="ml-1 w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Related Specialist Categories -->
  <section class="border-t border-hairline pt-6 mb-10 text-xs text-body-text select-none">
    <h3 class="font-semibold text-ink mb-3">Other Specialist Calculators</h3>
    <div class="flex flex-wrap gap-4">
      <a href="/cooking-baking" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Cooking & Baking</a>
      <a href="/scientific-lab" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Scientific & Lab</a>
      <a href="/construction-diy" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Construction & DIY</a>
      <a href="/sizing-automotive" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Sizing & Automotive</a>
      <a href="/finance-business" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Finance & Business</a>
    </div>
  </section>

  <!-- FAQs Section -->
  <section class="bg-card border border-hairline rounded-xl p-6 transition-colors mb-10 select-none">
    <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-4 font-mono">
      Engineering & Trade FAQs
    </h2>
    <FAQSchema faqs={faqs} />
  </section>
</BaseLayout>
