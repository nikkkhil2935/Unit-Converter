---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — MyUnitConverter"
  description="The page you are looking for does not exist on MyUnitConverter."
>
  <div class="flex-1 flex flex-col items-center justify-center pt-24 pb-24 text-center select-none">
    <div class="border border-hairline bg-card rounded-xl p-8 max-w-sm w-full shadow-[0_2px_8px_rgba(0,0,0,0.02)]">
      <h1 class="font-mono text-3xl font-bold text-brand-blue mb-2">404</h1>
      <h2 class="text-base font-semibold text-ink mb-3">Page Not Found</h2>
      <p class="text-xs text-muted-text leading-relaxed mb-6">
        The conversion pair or page you are looking for could not be found. Check the URL spelling or search on the homepage.
      </p>
      <a
        href="/"
        class="inline-block px-4 py-2 bg-brand-ink text-white dark:bg-white dark:text-black hover:opacity-90 text-xs font-semibold rounded-lg cursor-pointer transition-opacity"
      >
        Back to Home
      </a>
    </div>
  </div>
</BaseLayout>
