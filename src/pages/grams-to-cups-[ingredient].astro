---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ingredients, type Ingredient } from '../data/ingredientDensity';

export async function getStaticPaths() {
  return ingredients.map(ing => ({
    params: { ingredient: ing.slug },
    props: { ingredient: ing }
  }));
}

interface Props {
  ingredient: Ingredient;
}

const { ingredient } = Astro.props;

// Calculate default values
const gramsToCups = (g: number) => {
  return Math.round((g / ingredient.gramsPerCup) * 100) / 100;
};

const gramsToCupsPacked = (g: number) => {
  if (!ingredient.gramsPerCupPacked) return null;
  return Math.round((g / ingredient.gramsPerCupPacked) * 100) / 100;
};

const defaultCups = gramsToCups(100);

const packedText = ingredient.gramsPerCupPacked 
  ? ` or ${gramsToCupsPacked(100)} cups packed` 
  : '';

// Dynamic title & metadata following exact SEO Architecture rules
const title = `Grams to Cups: ${ingredient.name} | Density Weight to Volume Calculator`;
const description = `100g of ${ingredient.name.toLowerCase()} equals ${defaultCups} cups spooned${packedText}. Convert grams to cups instantly. Free, instant, no signup.`;

// SEO H1
const h1 = `Grams to Cups: ${ingredient.name} Converter`;

// Pull math division out of template strings
const tbspValue = Math.round((100 / ingredient.gramsPerTbsp) * 10) / 10;
const packedCups = ingredient.gramsPerCupPacked ? gramsToCupsPacked(100) : defaultCups;
const faqAnswer1 = `100 grams of ${ingredient.name} weighs approximately ${defaultCups} cups (spooned) or ${tbspValue} tablespoons. If packed, 100 grams is about ${packedCups} cups.`;
const faqAnswer3 = `200 grams of ${ingredient.name} is equal to ${gramsToCups(200)} cups (about 2 cups spooned).`;

const faqs = [
  {
    question: `How many cups in 100 grams of ${ingredient.name}?`,
    answer: faqAnswer1
  },
  {
    question: `How do I convert grams of ${ingredient.name} to cups?`,
    answer: `To convert grams of ${ingredient.name} to cups, divide the weight in grams by ${ingredient.gramsPerCup}. Formula: cups = grams ÷ ${ingredient.gramsPerCup}.`
  },
  {
    question: `What is 200 grams of ${ingredient.name} in cups?`,
    answer: faqAnswer3
  }
];

// Reference table increments
const tableValues = [25, 50, 100, 150, 200, 250, 300, 400, 500, 1000];
const tableRows = tableValues.map(val => {
  const cups = gramsToCups(val);
  const cupsPacked = gramsToCupsPacked(val);
  const cupsPackedStr = cupsPacked ? ` / Packed: ${cupsPacked} c` : '';
  
  let context = `Common recipe weight for ${ingredient.name.toLowerCase()}`;
  if (val === 100) context = "Standard baking weight";
  if (val === 500) context = "Half-kilogram metric size";

  const tbspVal = Math.round((val / ingredient.gramsPerTbsp) * 10) / 10;
  return {
    grams: `${val} g`,
    cups: `${cups} cups${cupsPackedStr}`,
    tbsp: `${tbspVal} tbsp`,
    context
  };
});

// JSON-LD schemas
const jsonLdFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const jsonLdHowTo = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": `How to Convert ${ingredient.name} from Grams to Cups`,
  "description": `Baking guide to convert grams of ${ingredient.name} to cups based on density.`,
  "step": [
    {
      "@type": "HowToStep",
      "name": "Enter the weight in grams",
      "text": "Input the grams value into the calculator above."
    },
    {
      "@type": "HowToStep",
      "name": "Select packing style",
      "text": `Determine if you want to measure spooned/sifted cups or packed cups.`
    },
    {
      "@type": "HowToStep",
      "name": "Read the converted cup measurement",
      "text": `Divide grams by ${ingredient.gramsPerCup} (or ${ingredient.gramsPerCupPacked || ingredient.gramsPerCup} if packed) to get cups.`
    }
  ]
};

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://myunitconverter.app"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Cooking",
      "item": "https://myunitconverter.app/cooking-converter"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": `Grams to Cups ${ingredient.name}`,
      "item": `https://myunitconverter.app/grams-to-cups-${ingredient.slug}`
    }
  ]
};

// Secondary answer string
const secondaryAnswer = ingredient.gramsPerCupPacked
  ? `Packed state: 100 grams of ${ingredient.name.toLowerCase()} = ${gramsToCupsPacked(100)} cups.`
  : `Or approximately ${tbspValue} tablespoons.`;
---

<BaseLayout
  title={title}
  description={description}
  categorySlug="cooking"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdFAQ)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  </Fragment>

  <!-- Visible Breadcrumbs -->
  <nav class="flex text-[10px] font-mono text-muted-text mt-6 mb-4 gap-1.5 items-center select-none" aria-label="Breadcrumb">
    <a href="/" class="hover:text-brand-blue transition-colors">Home</a>
    <span>/</span>
    <a href="/cooking-converter" class="hover:text-brand-blue transition-colors">Cooking Converter</a>
    <span>/</span>
    <span class="text-ink font-semibold">{ingredient.name} Grams to Cups</span>
  </nav>

  <!-- Title & Featured Snippet Bait -->
  <section class="mb-8">
    <h1 class="text-3xl font-extrabold tracking-tight text-ink mb-3">{h1}</h1>

    <!-- Direct Answer Block -->
    <div class="direct-answer bg-card border border-hairline rounded-xl p-5 mb-5 shadow-sm max-w-2xl">
      <p class="text-base text-ink mb-1">
        <strong>100 grams of {ingredient.name} = {defaultCups} cups spooned</strong>
      </p>
      <p class="text-xs text-body-text font-normal leading-relaxed">
        {secondaryAnswer}
      </p>
    </div>

    <p class="text-sm text-body-text max-w-2xl leading-relaxed">
      Convert grams to cups for <strong>{ingredient.name}</strong> instantly. Baking by weight is the most reliable method, but if a recipe requires cups, our converter handles the density conversions for you.
    </p>
  </section>

  <!-- Interactive Baking Calculator Widget -->
  <section 
    id="grams-to-cups-container"
    data-factor={ingredient.gramsPerCup}
    data-factor-packed={ingredient.gramsPerCupPacked || '0'}
    data-factor-tbsp={ingredient.gramsPerTbsp}
    class="mb-10 bg-card border border-hairline rounded-2xl p-6 max-w-2xl"
  >
    <h2 class="text-sm font-bold uppercase tracking-wider text-muted-text mb-4 font-mono">Interactive Grams to Cups Converter</h2>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
      <div>
        <label for="ingredient-select" class="block text-xs font-mono font-bold text-muted-text uppercase mb-1.5">Select Ingredient</label>
        <select
          id="ingredient-select"
          class="w-full bg-canvas border border-hairline text-ink rounded-lg p-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue font-medium transition-all"
        >
          {ingredients.map(ing => (
            <option value={ing.slug} selected={ing.slug === ingredient.slug}>{ing.name}</option>
          ))}
        </select>
      </div>

      <div>
        <label class="block text-xs font-mono font-bold text-muted-text uppercase mb-1.5">Conversion Direction</label>
        <div class="flex gap-2">
          <a href={`/cups-to-grams-${ingredient.slug}`} class="flex-1 text-center bg-canvas text-body-text border border-hairline hover:border-brand-blue rounded-lg py-2.5 text-xs font-medium font-mono">Cups → Grams</a>
          <a href={`/grams-to-cups-${ingredient.slug}`} class="flex-1 text-center bg-brand-blue/10 text-brand-blue border border-brand-blue/20 rounded-lg py-2.5 text-xs font-bold font-mono">Grams → Cups</a>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 items-end">
      <div>
        <label for="grams-input" class="block text-xs font-mono font-bold text-muted-text uppercase mb-1.5">Weight in Grams</label>
        <div class="relative">
          <input
            id="grams-input"
            type="number"
            step="1"
            value="100"
            min="0"
            class="w-full bg-canvas border border-hairline text-ink rounded-lg p-3 text-lg font-mono font-bold focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue transition-all"
          />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono font-bold text-muted-text">grams</span>
        </div>
      </div>

      <div class="space-y-3">
        <div class="p-3 bg-canvas border border-hairline rounded-lg flex justify-between items-center">
          <div>
            <span class="block text-[10px] font-bold text-muted-text uppercase font-mono">Volume (Spooned)</span>
            <span id="cups-result" class="text-xl font-mono font-bold text-brand-blue">{defaultCups} c</span>
          </div>
          <span class="text-xs font-mono font-medium text-muted-text" id="tbsp-result">({tbspValue} tbsp)</span>
        </div>

        {ingredient.gramsPerCupPacked && (
          <div class="p-3 bg-canvas border border-hairline rounded-lg flex justify-between items-center" id="packed-container">
            <div>
              <span class="block text-[10px] font-bold text-muted-text uppercase font-mono">Volume (Packed)</span>
              <span id="cups-packed-result" class="text-xl font-mono font-bold text-ink">{gramsToCupsPacked(100)} c</span>
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- 4-Column Reference Table -->
  <section class="mb-10 max-w-4xl">
    <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-4 font-mono">Grams to Cups Reference Matrix</h2>
    <div class="overflow-hidden border border-hairline rounded-xl">
      <table class="w-full border-collapse text-left text-xs">
        <thead>
          <tr class="bg-card border-b border-hairline text-muted-text font-mono text-[10px] uppercase">
            <th class="p-3 font-semibold">Weight (Grams)</th>
            <th class="p-3 font-semibold">Volume (Cups)</th>
            <th class="p-3 font-semibold">Volume (Tablespoons)</th>
            <th class="p-3 font-semibold">Real-world Context</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-hairline font-mono">
          {tableRows.map(row => (
            <tr class="hover:bg-card/50 transition-colors">
              <td class="p-3 text-ink font-medium">{row.grams}</td>
              <td class="p-3 text-brand-blue font-bold">{row.cups}</td>
              <td class="p-3 text-ink">{row.tbsp}</td>
              <td class="p-3 text-muted-text text-[11px]">{row.context}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Formula & Sibling Linking -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10 border-t border-hairline pt-8">
    <section>
      <h3 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-3 font-mono">The Math behind the Conversion</h3>
      <div class="p-4 bg-card border border-hairline rounded-xl space-y-3 font-sans">
        <p class="text-xs text-body-text leading-relaxed">
          Volume in cups is calculated by dividing weight in grams by ingredient density:
        </p>
        <div class="p-3 bg-canvas border border-hairline rounded-lg">
          <code class="font-mono text-sm font-semibold text-brand-blue">
            cups = grams ÷ {ingredient.gramsPerCup}
          </code>
        </div>
        <p class="text-xs text-body-text leading-relaxed">
          To convert grams directly to tablespoons:
          <code class="font-mono text-[11px] block mt-1.5 text-muted-text">
            tbsp = grams ÷ {ingredient.gramsPerTbsp}
          </code>
        </p>
      </div>
    </section>

    <section>
      <h3 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-3 font-mono">Popular Cooking Conversions</h3>
      <div class="grid grid-cols-2 gap-2 text-xs font-mono">
        <a href="/grams-to-cups-butter" class="p-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded truncate">Butter Grams to Cups</a>
        <a href="/grams-to-cups-sugar" class="p-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded truncate">Sugar Grams to Cups</a>
        <a href="/grams-to-cups-cocoa-powder" class="p-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded truncate">Cocoa Powder Grams to Cups</a>
        <a href="/recipe-scale-calculator" class="p-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded truncate col-span-2 text-center font-bold text-brand-blue">Recipe Scale Calculator</a>
      </div>
    </section>
  </div>

  <script>
    const container = document.getElementById('grams-to-cups-container');
    const factor = parseFloat(container?.getAttribute('data-factor') || '0');
    const factorPacked = parseFloat(container?.getAttribute('data-factor-packed') || '0');
    const factorTbsp = parseFloat(container?.getAttribute('data-factor-tbsp') || '0');

    const select = document.getElementById('ingredient-select') as HTMLSelectElement;
    const input = document.getElementById('grams-input') as HTMLInputElement;
    
    const cupsRes = document.getElementById('cups-result') as HTMLSpanElement;
    const tbspRes = document.getElementById('tbsp-result') as HTMLSpanElement;
    const cupsPackedRes = document.getElementById('cups-packed-result') as HTMLSpanElement;

    select?.addEventListener('change', (e) => {
      const val = (e.target as HTMLSelectElement).value;
      window.location.href = `/grams-to-cups-${val}`;
    });

    input?.addEventListener('input', (e) => {
      const grams = parseFloat((e.target as HTMLInputElement).value) || 0;
      
      const cups = Math.round((grams / factor) * 100) / 100;
      const tbsp = Math.round((grams / factorTbsp) * 10) / 10;
      
      if (cupsRes) cupsRes.textContent = `${cups} c`;
      if (tbspRes) tbspRes.textContent = `(${tbsp} tbsp)`;

      if (factorPacked > 0 && cupsPackedRes) {
        const pCups = Math.round((grams / factorPacked) * 100) / 100;
        cupsPackedRes.textContent = `${pCups} c`;
      }
    });
  </script>
</BaseLayout>
