---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryIcon from '../components/CategoryIcon';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import FAQSchema from '../components/FAQSchema.astro';

const title = "Cooking & Baking Calculators — Recipe Scale, Chart & Weight";
const description = "Free online cooking and baking calculators. Easily scale recipes, convert ingredient cups to grams, convert oven temperatures, and view reference charts.";

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Cooking & Baking', url: '/cooking-baking' }
];

const tools = [
  { label: "Flour Cups to Grams", href: "/cups-to-grams-flour", desc: "Convert flour measurements from US cups to grams for accurate baking results." },
  { label: "Butter Cups to Grams", href: "/cups-to-grams-butter", desc: "Convert butter from cups to grams or ounces for precise baking." },
  { label: "Sugar Cups to Grams", href: "/cups-to-grams-sugar", desc: "Convert granulated, brown, or powdered sugar cups to grams instantly." },
  { label: "Rice Cups to Grams", href: "/cups-to-grams-rice", desc: "Convert raw or cooked rice from cups to weight in grams." },
  { label: "Honey Cups to Grams", href: "/cups-to-grams-honey", desc: "Convert sticky honey measurements from cups to grams." },
  { label: "Milk Cups to Grams", href: "/cups-to-grams-milk", desc: "Convert milk and liquid dairy volume in cups to grams." },
  { label: "Oats Cups to Grams", href: "/cups-to-grams-oats", desc: "Convert rolled, instant, or steel-cut oats cups to grams." },
  { label: "Recipe Scale Calc", href: "/recipe-scale-calculator", desc: "Scale any recipe up or down by changing the target serving size." },
  { label: "Baking Chart", href: "/baking-conversion-chart", desc: "View the master weight and volume baking conversions reference chart." },
  { label: "Oven Temp (C/F)", href: "/oven-temperature-converter-c-to-f", desc: "Convert kitchen oven temperatures between Celsius and Fahrenheit." },
  { label: "Fan Oven Converter", href: "/fan-oven-temperature-converter", desc: "Adjust temperature and times when baking with convection fan ovens." },
  { label: "Gas Mark to C/F", href: "/gas-mark-to-celsius-to-fahrenheit", desc: "Convert traditional gas mark numbers to Celsius or Fahrenheit." },
  { label: "Candy Stage Temp", href: "/candy-making-temperature-stages-chart", desc: "Reference sugar syrup temperature stages for caramel, fudge, and candy." },
  { label: "Meat Internal Temp", href: "/meat-internal-temperature-guide-c-to-f", desc: "Safe minimum internal temperature cooking guide for beef, poultry, and pork." },
  { label: "Bread Proof Temp", href: "/proof-temperature-for-bread-c-to-f", desc: "Find optimal proofing temperature and humidity ranges for yeast dough." }
];

const faqs = [
  {
    question: "What is the best way to scale a recipe?",
    answer: "The best way to scale a recipe is by dividing your desired serving size by the original serving size to find the scaling factor. Then, multiply all ingredient quantities by this scaling factor. Our online Recipe Scale Calculator automates this math for you."
  },
  {
    question: "How do I convert cups to grams for baking?",
    answer: "Because cups measure volume and grams measure weight, the conversion depends on the density of the ingredient. For example, 1 cup of all-purpose flour weighs about 120 grams, while 1 cup of granulated sugar weighs about 200 grams. Use our ingredient-specific cups to grams converters for perfect accuracy."
  },
  {
    question: "What is the difference between fan oven and conventional oven temperature?",
    answer: "Fan (convection) ovens circulate hot air, cooking food faster and more efficiently. Generally, you should reduce the conventional recipe temperature by 20°C (about 25°F to 50°F) or decrease the cooking time by 15-20% when using a fan oven."
  }
];
---

<BaseLayout
  title={title}
  description={description}
  keywords="cooking calculators, baking conversion chart, cups to grams, recipe scale calculator, oven temperature converter, cooking measurements"
  canonicalPath="/cooking-baking"
  ogTitle={title}
  ogDescription={description}
>
  <BreadcrumbSchema crumbs={crumbs} />

  <!-- Title Section -->
  <section class="mb-8 select-none">
    <h1 class="text-3xl font-extrabold tracking-tight text-ink mb-2 flex items-center gap-2.5">
      <CategoryIcon id="cooking" className="w-8 h-8 text-brand-blue" />
      <span>Cooking & Baking Calculators</span>
    </h1>
    <p class="text-sm text-body-text max-w-2xl leading-relaxed">
      Easily scale recipe ingredients, convert kitchen measurements, adjust oven baking temperatures, and view comprehensive reference guides for cooking and baking.
    </p>
  </section>

  <!-- Tools Grid -->
  <section class="mb-10 select-none">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tools.map(tool => (
        <a
          href={tool.href}
          class="group block p-5 rounded-xl border border-hairline bg-card hover:border-brand-blue transition-all duration-200 hover:shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex flex-col justify-between cursor-pointer"
        >
          <div>
            <h2 class="font-semibold text-sm text-ink mb-2 group-hover:text-brand-blue transition-colors duration-200">
              {tool.label}
            </h2>
            <p class="text-xs text-body-text mb-4 leading-relaxed line-clamp-3">
              {tool.desc}
            </p>
          </div>
          <span
            class="inline-flex items-center text-[10px] font-semibold text-brand-blue opacity-80 group-hover:opacity-100 transition-opacity mt-auto pt-2"
          >
            Open calculator
            <svg class="ml-1 w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Related Specialist Categories -->
  <section class="border-t border-hairline pt-6 mb-10 text-xs text-body-text select-none">
    <h3 class="font-semibold text-ink mb-3">Other Specialist Calculators</h3>
    <div class="flex flex-wrap gap-4">
      <a href="/engineering-trade" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Engineering & Trade</a>
      <a href="/scientific-lab" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Scientific & Lab</a>
      <a href="/construction-diy" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Construction & DIY</a>
      <a href="/sizing-automotive" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Sizing & Automotive</a>
      <a href="/finance-business" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Finance & Business</a>
    </div>
  </section>

  <!-- FAQs Section -->
  <section class="bg-card border border-hairline rounded-xl p-6 transition-colors mb-10 select-none">
    <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-4 font-mono">
      Cooking & Baking FAQs
    </h2>
    <FAQSchema faqs={faqs} />
  </section>
</BaseLayout>
