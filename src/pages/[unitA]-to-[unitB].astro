---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConverterWidget from '../components/ConverterWidget';
import { categories, convert, getFormulaExplanation, type Category, type Unit } from '../lib/conversions';

export async function getStaticPaths() {
  const paths = [];
  for (const category of categories) {
    const units = category.units;
    for (const unitA of units) {
      for (const unitB of units) {
        if (unitA.id !== unitB.id) {
          paths.push({
            params: {
              unitA: unitA.id,
              unitB: unitB.id
            },
            props: {
              category,
              unitA,
              unitB
            }
          });
        }
      }
    }
  }
  return paths;
}

interface Props {
  category: Category;
  unitA: Unit;
  unitB: Unit;
}

const { category, unitA, unitB } = Astro.props;

// Formatting helper
const formatVal = (v: number) => {
  if (v === 0) return '0';
  const absV = Math.abs(v);
  if (absV < 1e-6 || absV > 1e12) return v.toExponential(4);
  return Number(v.toFixed(6)).toString();
};

// Generate conversion table values
const tableValues = [1, 2, 3, 5, 10, 20, 25, 50, 75, 100, 250, 500, 1000];
const conversions = tableValues.map(val => ({
  from: val,
  to: formatVal(convert(val, unitA.id, unitB.id, category.id))
}));

const title = `Convert ${unitA.name} to ${unitB.name} (${unitA.symbol} to ${unitB.symbol}) — Free Calculator`;
const description = `Instant online conversion of ${unitA.name.toLowerCase()}s to ${unitB.name.toLowerCase()}s (${unitA.symbol} to ${unitB.symbol}). Learn how to convert with formula, calculation examples, and conversion table.`;

// FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `How do you convert ${unitA.name.toLowerCase()}s to ${unitB.name.toLowerCase()}s?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `To convert ${unitA.name.toLowerCase()}s to ${unitB.name.toLowerCase()}s, multiply the value by the factor in the conversion formula: ${getFormulaExplanation(unitA.id, unitB.id, category.id)}.`
      }
    },
    {
      "@type": "Question",
      "name": `What is 1 ${unitA.name.toLowerCase()} in ${unitB.name.toLowerCase()}s?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `1 ${unitA.name.toLowerCase()} is equal to ${formatVal(convert(1, unitA.id, unitB.id, category.id))} ${unitB.name.toLowerCase()}s (${unitB.symbol}).`
      }
    },
    {
      "@type": "Question",
      "name": `What is the formula to convert ${unitA.name.toLowerCase()} to ${unitB.name.toLowerCase()}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The conversion formula is: ${getFormulaExplanation(unitA.id, unitB.id, category.id)}.`
      }
    }
  ]
};
---

<BaseLayout title={title} description={description}>
  <!-- Inject FAQ Schema JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <!-- Breadcrumb -->
  <nav class="flex text-[10px] font-mono text-muted-text mt-8 mb-4 gap-1.5 items-center select-none" aria-label="Breadcrumb">
    <a href="/" class="hover:text-brand-blue transition-colors">Home</a>
    <span>/</span>
    <a href={`/${category.id}-converter`} class="hover:text-brand-blue transition-colors">{category.name}</a>
    <span>/</span>
    <span class="text-ink font-semibold">{unitA.symbol} to {unitB.symbol}</span>
  </nav>

  <!-- Title Section -->
  <section class="mb-8 select-none">
    <h1 class="text-3xl font-extrabold tracking-tight text-ink mb-2">
      Convert {unitA.name} to {unitB.name}
    </h1>
    <p class="text-sm text-body-text max-w-2xl leading-relaxed">
      Convert {unitA.name.toLowerCase()}s to {unitB.name.toLowerCase()}s ({unitA.symbol} to {unitB.symbol}) instantly using this clean Vercel-styled calculator. Enter any value to get the bidirectional conversion results.
    </p>
  </section>

  <!-- Widget Island -->
  <section class="mb-10">
    <ConverterWidget 
      client:load 
      initialCategory={category.id} 
      initialFrom={unitA.id} 
      initialTo={unitB.id} 
    />
  </section>

  <!-- Split grid for Table and Formula Explanation -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10 select-none">
    
    <!-- Left: Conversion Table -->
    <section class="bg-card border border-hairline rounded-xl p-6 transition-colors">
      <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-4 font-mono">
        {unitA.name} to {unitB.name} Conversion Table
      </h2>
      <div class="overflow-hidden border border-hairline rounded-lg">
        <table class="w-full border-collapse text-left text-xs">
          <thead>
            <tr class="bg-canvas border-b border-hairline text-muted-text font-mono text-[10px] uppercase">
              <th class="p-3 font-semibold">{unitA.name} ({unitA.symbol})</th>
              <th class="p-3 font-semibold">{unitB.name} ({unitB.symbol})</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-hairline font-mono">
            {conversions.map(row => (
              <tr class="hover:bg-canvas/50 transition-colors">
                <td class="p-3 text-ink font-medium">{row.from}</td>
                <td class="p-3 text-brand-blue font-bold">{row.to}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Right: Calculation Details -->
    <section class="flex flex-col gap-6">
      
      <!-- Formula Explained -->
      <div class="bg-card border border-hairline rounded-xl p-6 transition-colors">
        <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-3 font-mono">
          How to Convert {unitA.name} to {unitB.name}
        </h2>
        <div class="p-4 bg-canvas border border-hairline rounded-lg mb-4">
          <p class="font-mono text-sm font-semibold text-brand-blue">
            {getFormulaExplanation(unitA.id, unitB.id, category.id)}
          </p>
        </div>
        <p class="text-xs text-body-text leading-relaxed">
          The formula to convert {unitA.name.toLowerCase()}s to {unitB.name.toLowerCase()}s is shown in the box above. 
          To find the value, simply plug in the number of {unitA.name.toLowerCase()}s and calculate.
        </p>
        <p class="text-xs text-body-text leading-relaxed mt-2">
          For example, to convert 10 {unitA.name.toLowerCase()}s, you calculate:
          <span class="block font-mono text-[11px] text-ink bg-canvas px-2 py-1.5 rounded border border-hairline mt-1">
            10 {unitA.symbol} = {formatVal(convert(10, unitA.id, unitB.id, category.id))} {unitB.symbol}
          </span>
        </p>
      </div>

      <!-- FAQ Section -->
      <div class="bg-card border border-hairline rounded-xl p-6 transition-colors">
        <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-4 font-mono">
          Frequently Asked Questions
        </h2>
        <div class="flex flex-col gap-4">
          <div>
            <h3 class="text-xs font-semibold text-ink mb-1">Q: How many {unitB.name.toLowerCase()}s are in a {unitA.name.toLowerCase()}?</h3>
            <p class="text-xs text-body-text">A: There is exactly {formatVal(convert(1, unitA.id, unitB.id, category.id))} {unitB.symbol} in 1 {unitA.symbol}.</p>
          </div>
          <div>
            <h3 class="text-xs font-semibold text-ink mb-1">Q: How do you do the math?</h3>
            <p class="text-xs text-body-text">A: Multiply your source value by the conversion factor to get the result in destination units.</p>
          </div>
        </div>
      </div>
      
    </section>
  </div>

</BaseLayout>
