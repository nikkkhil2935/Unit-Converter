---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConverterWidget from '../components/ConverterWidget';
import FAQSchema from '../components/FAQSchema.astro';
import { categories, convert, getFormulaExplanation, type Category, type Unit } from '../lib/conversions';
import { getPairSEO, getRealWorldContext, getEquivalent } from '../utils/seo';

export interface Props {
  category: Category;
  unitA: Unit;
  unitB: Unit;
  isRedirect: boolean;
  redirectTo?: string;
  canonicalPath: string;
}

export async function getStaticPaths() {
  const paths = [];
  for (const category of categories) {
    const units = category.units;
    for (let i = 0; i < units.length; i++) {
      for (let j = 0; j < units.length; j++) {
        if (i !== j) {
          const fromUnit = units[i];
          const toUnit = units[j];

          const canonicalSlug = `${fromUnit.slug}-to-${toUnit.slug}`;
          const legacySlug = `${fromUnit.id}-to-${toUnit.id}`;

          // 1. Primary Canonical SEO Slug Path (e.g. /cm-to-inches)
          paths.push({
            params: {
              unitA: fromUnit.slug,
              unitB: toUnit.slug
            },
            props: {
              category,
              unitA: fromUnit,
              unitB: toUnit,
              isRedirect: false,
              canonicalPath: `/${canonicalSlug}`
            }
          });

          // 2. Legacy ID Path (e.g. /centimeter-to-inch) redirecting to Canonical
          if (canonicalSlug !== legacySlug) {
            paths.push({
              params: {
                unitA: fromUnit.id,
                unitB: toUnit.id
              },
              props: {
                category,
                unitA: fromUnit,
                unitB: toUnit,
                isRedirect: true,
                redirectTo: `/${canonicalSlug}`,
                canonicalPath: `/${canonicalSlug}`
              }
            });
          }
        }
      }
    }
  }
  return paths;
}

const { category, unitA, unitB, isRedirect, redirectTo, canonicalPath } = Astro.props;

if (isRedirect && redirectTo) {
  // Static 301-like client-side redirect fallback
  return Astro.redirect(redirectTo, 301);
}

// Generate dynamic SEO titles and metadata
const seo = getPairSEO(unitA, unitB, category);
const realWorldParagraph = getRealWorldContext(unitA, unitB, category);

// Format output values nicely
const formatVal = (v: number) => {
  if (v === 0) return '0';
  const absV = Math.abs(v);
  if (absV < 1e-6 || absV > 1e12) return v.toExponential(4);
  return Number(v.toFixed(6)).toString();
};

const conversionFactor = formatVal(convert(1, unitA.id, unitB.id, category.id));

// Generate the 14-row Conversion Table
const tableValues = [0.001, 0.01, 0.1, 0.5, 1, 2, 5, 10, 25, 50, 100, 250, 500, 1000];
const conversions = tableValues.map(val => {
  const converted = convert(val, unitA.id, unitB.id, category.id);
  return {
    from: formatVal(val),
    to: formatVal(converted),
    equivalent: getEquivalent(converted, unitB.slug)
  };
});

// Dynamic FAQ list
const faqs = [
  {
    question: `How many ${unitB.name.toLowerCase()}s are in a ${unitA.name.toLowerCase()}?`,
    answer: `1 ${unitA.name} (${unitA.symbol}) is equal to ${conversionFactor} ${unitB.name} (${unitB.symbol}). To convert ${unitA.name.toLowerCase()}s to ${unitB.name.toLowerCase()}s, multiply your value by ${conversionFactor}.`
  },
  {
    question: `How do I convert ${unitA.name.toLowerCase()} to ${unitB.name.toLowerCase()}?`,
    answer: `To convert ${unitA.name} to ${unitB.name}, use the formula: ${unitB.name} = ${unitA.name} × ${conversionFactor}. For example, 5 ${unitA.symbol} = ${formatVal(convert(5, unitA.id, unitB.id, category.id))} ${unitB.symbol}.`
  },
  {
    question: `What is the formula for ${unitA.symbol} to ${unitB.symbol}?`,
    answer: `The formula is: ${unitB.symbol} = ${unitA.symbol} × ${conversionFactor}. This is based on the exact SI conversion factor. Use our calculator above to convert any value instantly.`
  }
];

// Generate dynamic 6 same-category links
// 3 starting with unitA, 3 ending with unitB
const siblingFrom = category.units
  .filter(u => u.slug !== unitA.slug && u.slug !== unitB.slug)
  .slice(0, 3)
  .map(u => ({
    label: `Convert ${unitA.symbol} to ${u.symbol}`,
    url: `/${unitA.slug}-to-${u.slug}`
  }));

const siblingTo = category.units
  .filter(u => u.slug !== unitA.slug && u.slug !== unitB.slug)
  .slice(0, 3)
  .map(u => ({
    label: `Convert ${u.symbol} to ${unitB.symbol}`,
    url: `/${u.slug}-to-${unitB.slug}`
  }));

const siblingLinks = [...siblingFrom, ...siblingTo];

// Related categories
const categoryMap = categories.reduce((acc, c) => {
  acc[c.slug] = c.name;
  return acc;
}, {} as Record<string, string>);

const relatedCategories = category.relatedCategories.map(slug => ({
  name: categoryMap[slug] || slug,
  url: `/${slug}-converter`
}));

// Popular footer conversions
const popularFooterConversions = [
  { label: "cm to inches", url: "/cm-to-inches" },
  { label: "kg to lbs", url: "/kg-to-lbs" },
  { label: "Celsius to Fahrenheit", url: "/celsius-to-fahrenheit" },
  { label: "mm to inches", url: "/mm-to-inches" },
  { label: "meters to feet", url: "/meters-to-feet" },
  { label: "km to miles", url: "/km-to-miles" },
  { label: "feet to cm", url: "/feet-to-cm" },
  { label: "grams to ounces", url: "/grams-to-ounces" },
  { label: "inches to cm", url: "/inches-to-cm" },
  { label: "liters to gallons", url: "/liters-to-gallons" },
  { label: "mph to kph", url: "/mph-to-kph" },
  { label: "acres to sq ft", url: "/acres-to-sqft" }
];

// Build JSON-LD objects
const jsonLdHowTo = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": `How to Convert ${unitA.name} to ${unitB.name}`,
  "description": `Step-by-step guide to convert ${unitA.name} (${unitA.symbol}) to ${unitB.name} (${unitB.symbol}) using the formula and our free calculator.`,
  "step": [
    {
      "@type": "HowToStep",
      "name": `Enter your ${unitA.name} value`,
      "text": `Type the number of ${unitA.name} you want to convert into the input field above.`
    },
    {
      "@type": "HowToStep",
      "name": `Select ${unitA.name} as the From unit`,
      "text": `Make sure '${unitA.name} (${unitA.symbol})' is selected in the left dropdown.`
    },
    {
      "@type": "HowToStep",
      "name": `Select ${unitB.name} as the To unit`,
      "text": `Choose '${unitB.name} (${unitB.symbol})' in the right dropdown.`
    },
    {
      "@type": "HowToStep",
      "name": "Read your result",
      "text": `The converted value in ${unitB.name} appears instantly. No button click required.`
    }
  ]
};

const jsonLdMathSolver = {
  "@context": "https://schema.org",
  "@type": "MathSolver",
  "name": `${unitA.name} to ${unitB.name} Converter`,
  "url": `https://myunitconverter.app${canonicalPath}`,
  "description": `Converts ${unitA.name} to ${unitB.name} using the formula: ${unitB.symbol} = ${unitA.symbol} × ${conversionFactor}`
};

const jsonLdFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://myunitconverter.app"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": `${category.name} Converter`,
      "item": `https://myunitconverter.app/${category.slug}-converter`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": `${unitA.name} to ${unitB.name}`,
      "item": `https://myunitconverter.app${canonicalPath}`
    }
  ]
};

// Calculate Inverse Formula
const inverseFactor = formatVal(1 / convert(1, unitA.id, unitB.id, category.id));

// Generate Mental Math Tip
const getMentalMathTip = () => {
  if (category.slug === 'temperature') {
    if (unitA.slug === 'celsius' && unitB.slug === 'fahrenheit') {
      return "Double the Celsius temperature and add 30 for a quick mental estimate.";
    }
    if (unitA.slug === 'fahrenheit' && unitB.slug === 'celsius') {
      return "Subtract 30 and half the Fahrenheit temperature for a quick mental estimate.";
    }
    return "Use our instant calculator above to avoid complex temperature offset math.";
  }
  const f = convert(1, unitA.id, unitB.id, category.id);
  if (f === 1) return "The units are equivalent; no math is required.";
  
  if (Math.abs(f - 2.54) < 0.01) {
    return "Divide the centimeters value by 2.5 (or divide by 5 and multiply by 2) for a fast estimate.";
  }
  if (Math.abs(f - 0.3048) < 0.01) {
    return "Divide the feet value by 3 to get a rough estimate in meters.";
  }
  if (Math.abs(f - 0.45359) < 0.01) {
    return "Divide the pounds value by 2 and subtract 10% for a quick weight estimate.";
  }
  if (Math.abs(f - 1.60934) < 0.01) {
    return "Multiply the miles value by 1.6 to quickly estimate the distance in kilometers.";
  }
  
  if (f > 1) {
    const rounded = Math.round(f * 10) / 10;
    return `Multiply the value by roughly ${rounded} to calculate the equivalent amount in your head.`;
  } else {
    const roundedDiv = Math.round((1 / f) * 10) / 10;
    return `Divide the value by roughly ${roundedDiv} to quickly estimate the converted result.`;
  }
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords.join(', ')}
  canonicalPath={canonicalPath}
  categorySlug={category.slug}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdFAQ)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdMathSolver)} />
  </Fragment>

  <!-- Visible Breadcrumb Trail -->
  <nav class="flex text-[10px] font-mono text-muted-text mt-6 mb-4 gap-1.5 items-center select-none" aria-label="Breadcrumb">
    <a href="/" class="hover:text-brand-blue transition-colors">Home</a>
    <span class="mx-0.5 text-muted-text/60">/</span>
    <a href={`/${category.slug}-converter`} class="hover:text-brand-blue transition-colors">{category.name} Converter</a>
    <span class="mx-0.5 text-muted-text/60">/</span>
    <span class="text-ink font-semibold">{unitA.symbol} to {unitB.symbol}</span>
  </nav>

  <!-- Title & Direct Answer Section (Snippet Optimization) -->
  <section class="mb-8 select-none">
    <h1 class="text-3xl font-extrabold tracking-tight text-ink mb-3">
      {seo.h1}
    </h1>
    
    <!-- Direct Answer Snippet for Position 0 -->
    <div class="direct-answer bg-card border border-hairline rounded-xl p-5 mb-5 shadow-sm max-w-2xl select-text">
      <p class="text-base text-ink mb-1">
        <strong>1 {unitA.name} = {conversionFactor} {unitB.name}</strong>
      </p>
      <p class="text-xs text-body-text font-normal leading-relaxed">
        To convert {unitA.name.toLowerCase()}s to {unitB.name.toLowerCase()}s, multiply by {conversionFactor}.
      </p>
    </div>

    <!-- Context Paragraph -->
    <p class="text-sm text-body-text max-w-2xl leading-relaxed select-text">
      {realWorldParagraph}
    </p>
  </section>

  <!-- Interactive Converter Widget -->
  <section class="mb-10">
    <ConverterWidget 
      client:load 
      initialCategory={category.id} 
      initialFrom={unitA.id} 
      initialTo={unitB.id} 
    />
  </section>

  <!-- Split Grid for Table and Formulas -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10 select-none">
    
    <!-- Left: Conversion Table (14 rows) -->
    <section class="bg-card border border-hairline rounded-xl p-6 transition-colors">
      <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-4 font-mono">
        {seo.h2variants[2]}
      </h2>
      <div class="overflow-hidden border border-hairline rounded-lg">
        <table class="w-full border-collapse text-left text-xs">
          <thead>
            <tr class="bg-canvas border-b border-hairline text-muted-text font-mono text-[10px] uppercase">
              <th class="p-3 font-semibold">{unitA.name} ({unitA.symbol})</th>
              <th class="p-3 font-semibold">{unitB.name} ({unitB.symbol})</th>
              <th class="p-3 font-semibold hidden sm:table-cell">Real-world equivalent</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-hairline font-mono">
            {conversions.map(row => (
              <tr class="hover:bg-canvas/50 transition-colors">
                <td class="p-3 text-ink font-medium">{row.from}</td>
                <td class="p-3 text-brand-blue font-bold">{row.to}</td>
                <td class="p-3 text-muted-text text-[11px] hidden sm:table-cell">{row.equivalent}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Right: Formulas & Dynamic Details -->
    <section class="flex flex-col gap-6">
      
      <!-- Formula Explanation Block -->
      <div class="bg-card border border-hairline rounded-xl p-6 transition-colors">
        <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-3 font-mono">
          {seo.h2variants[1]}
        </h2>
        <div class="space-y-4">
          <div class="p-4 bg-canvas border border-hairline rounded-lg">
            <span class="block text-[10px] font-bold text-muted-text uppercase font-mono mb-1.5">Direct Formula</span>
            <code class="font-mono text-sm font-semibold text-brand-blue">
              {getFormulaExplanation(unitA.id, unitB.id, category.id)}
            </code>
          </div>
          
          <div class="p-4 bg-canvas border border-hairline rounded-lg">
            <span class="block text-[10px] font-bold text-muted-text uppercase font-mono mb-1.5">Inverse Formula</span>
            <code class="font-mono text-sm font-semibold text-body-text">
              {unitA.symbol} = {unitB.symbol} × {inverseFactor}
            </code>
          </div>

          <div class="p-4 bg-canvas border border-hairline rounded-lg">
            <span class="block text-[10px] font-bold text-muted-text uppercase font-mono mb-1.5">Mental Math Shortcut</span>
            <p class="text-xs text-body-text leading-relaxed font-sans mt-0.5">
              {getMentalMathTip()}
            </p>
          </div>
        </div>
      </div>

      <!-- Common Value Searches (Targeting specific searches) -->
      <div class="bg-card border border-hairline rounded-xl p-6 transition-colors">
        <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-3 font-mono">
          Common {unitA.name} to {unitB.name} Calculations
        </h2>
        <ul class="space-y-2 text-xs font-mono text-body-text">
          <li>5 {unitA.symbol} = {formatVal(convert(5, unitA.id, unitB.id, category.id))} {unitB.symbol}</li>
          <li>10 {unitA.symbol} = {formatVal(convert(10, unitA.id, unitB.id, category.id))} {unitB.symbol}</li>
          <li>50 {unitA.symbol} = {formatVal(convert(50, unitA.id, unitB.id, category.id))} {unitB.symbol}</li>
          <li>100 {unitA.symbol} = {formatVal(convert(100, unitA.id, unitB.id, category.id))} {unitB.symbol}</li>
          <li>500 {unitA.symbol} = {formatVal(convert(500, unitA.id, unitB.id, category.id))} {unitB.symbol}</li>
        </ul>
      </div>

    </section>
  </div>

  <!-- FAQs Accordion UI -->
  <section class="bg-card border border-hairline rounded-xl p-6 mb-10 transition-colors">
    <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-4 font-mono">
      {seo.h2variants[0]}
    </h2>
    <FAQSchema faqs={faqs} />
  </section>

  <!-- Internal Linking Sections (PILLAR 4) -->
  <section class="border-t border-hairline pt-8 pb-12 text-xs text-body-text select-none">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      <!-- Reverse & Sibling Links -->
      <div class="flex flex-col gap-6">
        <div>
          <h3 class="font-bold text-ink uppercase tracking-wider text-[10px] font-mono mb-2">Reverse Conversion</h3>
          <a href={`/${unitB.slug}-to-${unitA.slug}`} class="text-brand-blue font-semibold hover:underline inline-flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Convert {unitB.name} to {unitA.name}
          </a>
        </div>

        <div>
          <h3 class="font-bold text-ink uppercase tracking-wider text-[10px] font-mono mb-3">Other {category.name} Conversions</h3>
          <div class="grid grid-cols-2 gap-2">
            {siblingLinks.map(sibling => (
              <a href={sibling.url} class="p-2 border border-hairline bg-canvas hover:border-brand-blue hover:text-brand-blue rounded font-mono text-[11px] truncate">
                {sibling.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Related Categories & Popular Conversions -->
      <div class="flex flex-col gap-6">
        <div>
          <h3 class="font-bold text-ink uppercase tracking-wider text-[10px] font-mono mb-3">Related Measurement Types</h3>
          <div class="flex flex-wrap gap-2">
            {relatedCategories.map(cat => (
              <a href={cat.url} class="px-3 py-1.5 border border-hairline bg-canvas hover:border-brand-blue hover:text-brand-blue rounded-full font-medium">
                {cat.name} Converter
              </a>
            ))}
            <a href={`/${category.slug}-converter`} class="px-3 py-1.5 border border-hairline bg-canvas hover:border-brand-blue hover:text-brand-blue rounded-full font-semibold">
              All {category.name} Units
            </a>
          </div>
        </div>

        <div>
          <h3 class="font-bold text-ink uppercase tracking-wider text-[10px] font-mono mb-3">Popular Converter Links</h3>
          <div class="flex flex-wrap gap-x-3 gap-y-1.5 text-[11px] text-muted-text font-mono">
            {popularFooterConversions.map((link, idx) => (
              <span>
                {idx > 0 && <span class="mr-2 text-hairline">|</span>}
                <a href={link.url} class="hover:text-brand-blue transition-colors">
                  {link.label}
                </a>
              </span>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
