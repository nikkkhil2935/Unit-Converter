---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ingredients } from '../data/ingredientDensity';

const categories = [
  { id: 'all', name: 'All Ingredients' },
  { id: 'baking', name: 'Flours & Starches' },
  { id: 'sweeteners', name: 'Sugars & Sweeteners' },
  { id: 'dairy-fats', name: 'Dairy & Fats' },
  { id: 'powders', name: 'Spices & Leaveners' },
  { id: 'nuts-seeds', name: 'Nuts, Seeds & Fruits' }
];

// Title & Meta tags
const title = "Baking Conversion Chart | Cups to Grams & Ounces Matrix";
const description = "Comprehensive cooking conversion chart for flours, sugars, butter, liquids, and 50+ ingredients. Free baking density reference matrix.";

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://myunitconverter.app"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Cooking",
      "item": "https://myunitconverter.app/cooking-converter"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Baking Conversion Chart",
      "item": "https://myunitconverter.app/baking-conversion-chart"
    }
  ]
};
---

<BaseLayout
  title={title}
  description={description}
  categorySlug="cooking"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  </Fragment>

  <!-- Visible Breadcrumbs -->
  <nav class="flex text-[10px] font-mono text-muted-text mt-6 mb-4 gap-1.5 items-center select-none" aria-label="Breadcrumb">
    <a href="/" class="hover:text-brand-blue transition-colors">Home</a>
    <span>/</span>
    <a href="/cooking-converter" class="hover:text-brand-blue transition-colors">Cooking Converter</a>
    <span>/</span>
    <span class="text-ink font-semibold">Baking Conversion Chart</span>
  </nav>

  <!-- Header -->
  <section class="mb-8">
    <h1 class="text-3xl font-extrabold tracking-tight text-ink mb-3">Baking Conversion Chart</h1>
    <p class="text-sm text-body-text max-w-2xl leading-relaxed">
      A comprehensive weight-to-volume density chart for bakers. Compare cups, tablespoons, grams, and ounces for common baking ingredients. Click any ingredient name to open its interactive dedicated calculator.
    </p>
  </section>

  <!-- Filter buttons -->
  <div class="flex flex-wrap gap-2 mb-6">
    {categories.map(cat => (
      <button
        data-filter-id={cat.id}
        class={`filter-btn px-3.5 py-1.5 text-xs font-mono rounded-full border border-hairline transition-all duration-200 cursor-pointer select-none font-medium ${cat.id === 'all' ? 'bg-brand-blue/15 border-brand-blue/30 text-brand-blue' : 'bg-card text-muted-text hover:border-brand-blue hover:text-brand-blue'}`}
      >
        {cat.name}
      </button>
    ))}
  </div>

  <!-- Reference Chart Matrix Table -->
  <section class="mb-10 overflow-hidden border border-hairline rounded-xl">
    <table class="w-full border-collapse text-left text-xs font-mono">
      <thead>
        <tr class="bg-card border-b border-hairline text-muted-text text-[10px] uppercase font-mono">
          <th class="p-3 font-semibold">Ingredient</th>
          <th class="p-3 font-semibold">1 Cup (grams)</th>
          <th class="p-3 font-semibold">1 Cup (ounces)</th>
          <th class="p-3 font-semibold">1 Tbsp (grams)</th>
          <th class="p-3 font-semibold">Category</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-hairline">
        {ingredients.map(ing => {
          const cupsGrams = ing.gramsPerCup;
          const cupsOz = Math.round((cupsGrams / 28.349523125) * 10) / 10;
          const tbspGrams = ing.gramsPerTbsp;
          
          return (
            <tr
              data-ingredient-category={ing.category}
              class="ingredient-row hover:bg-card/40 transition-colors"
            >
              <td class="p-3 font-sans font-medium text-ink">
                <a href={`/cups-to-grams-${ing.slug}`} class="text-brand-blue hover:underline">
                  {ing.name}
                </a>
              </td>
              <td class="p-3 text-ink font-bold">{cupsGrams}g{ing.gramsPerCupPacked ? ` / ${ing.gramsPerCupPacked}g packed` : ''}</td>
              <td class="p-3 text-muted-text">{cupsOz} oz</td>
              <td class="p-3 text-ink">{tbspGrams}g</td>
              <td class="p-3 text-[10px] text-muted-text uppercase font-bold">{ing.category}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </section>

  <!-- Baking conversions explanation -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 border-t border-hairline pt-8 mb-10 text-xs text-body-text">
    <section>
      <h3 class="font-bold text-ink uppercase tracking-wider text-[10px] font-mono mb-2">Cup Weights vs. Spooned Weights</h3>
      <p class="leading-relaxed mb-3">
        In standard recipes, a cup of flour can range from 110g to 160g depending on how it was put into the cup.
      </p>
      <ul class="list-disc pl-4 space-y-2 leading-relaxed">
        <li><strong>Spooned / Spooned-and-Swept:</strong> The standard baking method. Flour is spooned lightly into the measuring cup, then swept level. 1 cup of AP flour spooned is 120 grams.</li>
        <li><strong>Packed:</strong> Scooping directly from the bag packs the flour tightly. 1 cup of packed AP flour can weigh 150 grams or more, representing a 25% error!</li>
      </ul>
    </section>

    <section>
      <h3 class="font-bold text-ink uppercase tracking-wider text-[10px] font-mono mb-2">Why Weight is Essential</h3>
      <p class="leading-relaxed">
        By using a digital kitchen scale and converting recipes to weights, you eliminate the variations caused by humidity, flour compaction, and scoop size. Professional bakers always compile their formulas in percentages and absolute weights (grams) rather than volumetric scoops.
      </p>
    </section>
  </div>

  <script>
    const filterBtns = document.querySelectorAll('.filter-btn');
    const rows = document.querySelectorAll('.ingredient-row');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Toggle active styles
        filterBtns.forEach(b => {
          b.classList.remove('bg-brand-blue/15', 'border-brand-blue/30', 'text-brand-blue');
          b.classList.add('bg-card', 'text-muted-text');
        });
        btn.classList.add('bg-brand-blue/15', 'border-brand-blue/30', 'text-brand-blue');
        btn.classList.remove('bg-card', 'text-muted-text');

        const categoryId = btn.getAttribute('data-filter-id');

        rows.forEach(row => {
          const rowCat = row.getAttribute('data-ingredient-category');
          if (categoryId === 'all' || rowCat === categoryId) {
            (row as HTMLElement).style.display = '';
          } else {
            (row as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>
