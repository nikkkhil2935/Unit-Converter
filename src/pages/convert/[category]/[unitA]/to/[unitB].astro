---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import ConverterWidget from '../../../../../components/ConverterWidget';
import { categories, type Category, type Unit } from '../../../../../lib/conversions';

export async function getStaticPaths() {
  const paths = [];
  for (const category of categories) {
    const units = category.units;
    for (const unitA of units) {
      for (const unitB of units) {
        if (unitA.id !== unitB.id) {
          paths.push({
            params: {
              category: category.id,
              unitA: unitA.id,
              unitB: unitB.id
            },
            props: {
              category,
              unitA,
              unitB
            }
          });
        }
      }
    }
  }
  return paths;
}

interface Props {
  category: Category;
  unitA: Unit;
  unitB: Unit;
}

const { category, unitA, unitB } = Astro.props;

const title = `Convert ${unitA.name} to ${unitB.name} (${unitA.symbol} to ${unitB.symbol}) — Live Calculator`;
const description = `Live online conversion for ${category.name.toLowerCase()} from ${unitA.name.toLowerCase()} to ${unitB.name.toLowerCase()}. Free and shareable.`;
---

<BaseLayout title={title} description={description}>
  <!-- Breadcrumb -->
  <nav class="flex text-[10px] font-mono text-muted-text mt-8 mb-4 gap-1.5 items-center select-none" aria-label="Breadcrumb">
    <a href="/" class="hover:text-brand-blue transition-colors">Home</a>
    <span>/</span>
    <a href={`/${category.id}-converter`} class="hover:text-brand-blue transition-colors">{category.name}</a>
    <span>/</span>
    <span class="text-ink font-semibold">{unitA.symbol} to {unitB.symbol}</span>
  </nav>

  <!-- Title Section -->
  <section class="mb-8 select-none">
    <h1 class="text-3xl font-extrabold tracking-tight text-ink mb-2">
      Convert {unitA.name} to {unitB.name}
    </h1>
    <p class="text-sm text-body-text max-w-2xl leading-relaxed">
      You are viewing the dedicated conversion route for {unitA.name.toLowerCase()} to {unitB.name.toLowerCase()}. Set values below, bookmark this URL, or share it with others.
    </p>
  </section>

  <!-- Interactive Converter Widget Island -->
  <section class="mb-10">
    <ConverterWidget 
      client:load 
      initialCategory={category.id} 
      initialFrom={unitA.id} 
      initialTo={unitB.id} 
    />
  </section>

  <!-- Back Link -->
  <div class="mt-6 flex justify-start select-none">
    <a href={`/${unitA.id}-to-${unitB.id}`} class="inline-flex items-center text-xs font-semibold text-brand-blue hover:underline gap-1 cursor-pointer">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Go to main SEO details page
    </a>
  </div>
</BaseLayout>
