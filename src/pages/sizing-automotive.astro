---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryIcon from '../components/CategoryIcon';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import FAQSchema from '../components/FAQSchema.astro';

const title = "Sizing & Automotive Calculators — Clothing, Tires, Heights";
const description = "Free online sizing and automotive calculators. Convert US to EU shoe and dress sizes, check ring sizes, calculate tire size speedometer differences, and compound units.";

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Sizing & Automotive', url: '/sizing-automotive' }
];

const tools = [
  { label: "Shoe Size US/EU/UK", href: "/shoe-size-converter-us-to-eu", desc: "Convert shoe sizes across US, UK, Europe, and international Mondopoint scales." },
  { label: "Dress Size US/UK/EU", href: "/dress-size-converter-us-to-uk", desc: "Convert women's dress sizes between US, UK, European, and Italian standards." },
  { label: "Ring Size US/UK/EU", href: "/ring-size-converter-us-to-uk", desc: "Find your finger size using diameter and circumference ring measurements." },
  { label: "Tire Size Speedometer", href: "/tire-size-calculator", desc: "Calculate speedometer reading differences when switching to larger or smaller tires." },
  { label: "Feet & Inches to cm", href: "/feet-and-inches-to-cm", desc: "Convert standard imperial height (feet and inches) to metric centimeters (cm)." },
  { label: "Pounds & Ounces to kg", href: "/pounds-and-ounces-to-kg", desc: "Convert compound weight units (pounds and ounces) to metric kilograms (kg)." },
  { label: "Hours/Mins to Seconds", href: "/hours-minutes-seconds-to-seconds", desc: "Convert compound time values (hours, minutes, and seconds) directly into total seconds." }
];

const faqs = [
  {
    question: "How do shoe size conversions work between US and EU?",
    answer: "European shoe sizes are calculated using 'Paris Points' (each point is 2/3 of a centimeter). For example, a US Men's size 10 is roughly equivalent to a European size 43. Conversions vary slightly between men's, women's, and kids' sizes."
  },
  {
    question: "Why does changing tire size affect the speedometer?",
    answer: "The speedometer calculates speed based on how fast the tires rotate. If you install larger tires, the tire has a larger outer circumference and travels further per rotation. This causes your speedometer to read slower than your actual vehicle speed."
  },
  {
    question: "How do I measure my ring size at home?",
    answer: "Wrap a thin piece of paper or string snugly around the base of your finger. Mark the spot where the ends meet, and measure that length with a millimeter ruler to find the circumference. Use our Ring Size chart to match that length to your size."
  }
];
---

<BaseLayout
  title={title}
  description={description}
  keywords="sizing calculators, shoe size converter, dress size chart, ring size chart, tire size calculator, speedometer error, height converter"
  canonicalPath="/sizing-automotive"
  ogTitle={title}
  ogDescription={description}
>
  <BreadcrumbSchema crumbs={crumbs} />

  <!-- Title Section -->
  <section class="mb-8 select-none">
    <h1 class="text-3xl font-extrabold tracking-tight text-ink mb-2 flex items-center gap-2.5">
      <CategoryIcon id="speed" className="w-8 h-8 text-brand-blue" />
      <span>Sizing & Automotive Calculators</span>
    </h1>
    <p class="text-sm text-body-text max-w-2xl leading-relaxed">
      Quick charts and estimators for international shoe and apparel sizes, custom tire dimensions, speedometer calibration offsets, and compound unit mappings.
    </p>
  </section>

  <!-- Tools Grid -->
  <section class="mb-10 select-none">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tools.map(tool => (
        <a
          href={tool.href}
          class="group block p-5 rounded-xl border border-hairline bg-card hover:border-brand-blue transition-all duration-200 hover:shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex flex-col justify-between cursor-pointer"
        >
          <div>
            <h2 class="font-semibold text-sm text-ink mb-2 group-hover:text-brand-blue transition-colors duration-200">
              {tool.label}
            </h2>
            <p class="text-xs text-body-text mb-4 leading-relaxed line-clamp-3">
              {tool.desc}
            </p>
          </div>
          <span
            class="inline-flex items-center text-[10px] font-semibold text-brand-blue opacity-80 group-hover:opacity-100 transition-opacity mt-auto pt-2"
          >
            Open calculator
            <svg class="ml-1 w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Related Specialist Categories -->
  <section class="border-t border-hairline pt-6 mb-10 text-xs text-body-text select-none">
    <h3 class="font-semibold text-ink mb-3">Other Specialist Calculators</h3>
    <div class="flex flex-wrap gap-4">
      <a href="/cooking-baking" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Cooking & Baking</a>
      <a href="/engineering-trade" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Engineering & Trade</a>
      <a href="/scientific-lab" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Scientific & Lab</a>
      <a href="/construction-diy" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Construction & DIY</a>
      <a href="/finance-business" class="px-3 py-2 border border-hairline bg-card hover:border-brand-blue hover:text-brand-blue rounded-lg font-medium transition-all">Finance & Business</a>
    </div>
  </section>

  <!-- FAQs Section -->
  <section class="bg-card border border-hairline rounded-xl p-6 transition-colors mb-10 select-none">
    <h2 class="text-xs font-bold uppercase tracking-wider text-muted-text mb-4 font-mono">
      Sizing & Automotive FAQs
    </h2>
    <FAQSchema faqs={faqs} />
  </section>
</BaseLayout>
