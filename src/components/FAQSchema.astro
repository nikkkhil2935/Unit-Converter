---
interface FAQ {
  question: string;
  answer: string;
}

export interface Props {
  faqs: FAQ[];
}

const { faqs } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<!-- JSON-LD FAQ Schema -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<!-- Visible Accordion UI -->
<div class="divide-y divide-hairline border-y border-hairline w-full select-none">
  {faqs.map((faq, index) => (
    <details class="group py-4" open={index === 0}>
      <summary class="flex justify-between items-center text-base font-semibold text-ink cursor-pointer list-none select-none focus:outline-none w-full">
        <span class="pr-4">{faq.question}</span>
        <span class="text-muted-text transition-transform duration-200 group-open:rotate-180 flex-shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </span>
      </summary>
      <div class="mt-2 text-[15px] font-normal leading-[1.6] text-muted-text max-w-3xl">
        {faq.answer}
      </div>
    </details>
  ))}
</div>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
