---
import CategoryIcon from './CategoryIcon';

export interface Props {
  category: {
    id: string;
    name: string;
    icon: string;
    description: string;
    units: { id: string; name: string; symbol: string }[];
    popularPairs: [string, string][];
  }
}

const { category } = Astro.props;

// Format pair display
const displayPairs = category.popularPairs.slice(0, 3).map(([from, to]) => {
  const fromUnit = category.units.find(u => u.id === from);
  const toUnit = category.units.find(u => u.id === to);
  return {
    label: `${fromUnit?.symbol || from} → ${toUnit?.symbol || to}`,
    href: `/${from}-to-${to}`
  };
});
---
<div
  data-category-name={category.name}
  data-category-desc={category.description}
  class="group block p-5 rounded-xl border border-hairline bg-card hover:border-brand-blue transition-all duration-200 hover:shadow-[0_4px_12px_rgba(0,0,0,0.02)]"
>
  <a href={`/${category.id}-converter`} class="block select-none">
    <!-- Header -->
    <div class="flex items-start justify-between mb-3">
      <div class="flex items-center gap-2.5">
        <CategoryIcon id={category.id} className="w-5 h-5 text-brand-blue" />
        <h2 class="font-semibold text-sm text-ink">{category.name}</h2>
      </div>
      <span class="text-[10px] text-muted-text border border-hairline px-2 py-0.5 rounded-full font-mono bg-canvas">
        {category.units.length} units
      </span>
    </div>

    <!-- Description -->
    <p class="text-xs text-body-text mb-4 leading-relaxed line-clamp-2 min-h-[2.5rem]">
      {category.description}
    </p>
  </a>

  <!-- Popular links -->
  <div class="flex flex-wrap gap-1.5 mb-2">
    {displayPairs.map(pair => (
      <a
        href={pair.href}
        class="text-[10px] font-mono px-2 py-1 rounded border border-hairline bg-canvas text-body-text hover:border-brand-blue hover:text-brand-blue transition-colors duration-200"
      >
        {pair.label}
      </a>
    ))}
  </div>

  <!-- Arrow view all -->
  <a
    href={`/${category.id}-converter`}
    class="inline-flex items-center text-[10px] font-semibold text-brand-blue opacity-80 group-hover:opacity-100 transition-opacity mt-2 cursor-pointer"
  >
    View {category.name} converter
    <svg class="ml-1 w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
    </svg>
  </a>
</div>
