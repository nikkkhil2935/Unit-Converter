---
---
<div class="relative w-full max-w-lg mx-auto mb-10">
  <div class="relative shadow-[0_1px_2px_rgba(0,0,0,0.02)]">
    <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-text" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z"/>
    </svg>
    <input
      id="global-search"
      type="text"
      data-t="searchPlaceholder"
      placeholder="Type a conversion (e.g., '25 kg to lbs') or search categories..."
      class="w-full pl-10 pr-16 py-3 rounded-lg border border-hairline bg-card text-sm text-ink placeholder-muted-text focus:outline-none focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue transition-all"
    />
    <button
      id="search-clear"
      class="hidden absolute right-3 top-1/2 -translate-y-1/2 text-[10px] text-muted-text hover:text-ink cursor-pointer px-2 py-0.5 border border-hairline bg-canvas rounded font-medium select-none"
    >
      Clear
    </button>
  </div>

  <!-- Instant conversion result card -->
  <div id="instant-result" class="hidden mt-4 p-5 bg-card border border-hairline rounded-xl shadow-[0_4px_16px_rgba(0,0,0,0.04)] relative overflow-hidden transition-all duration-300">
    <div class="absolute top-0 left-0 w-1.5 h-full bg-brand-blue"></div>
    <div class="flex justify-between items-start mb-2">
      <span class="text-[10px] uppercase font-bold tracking-wider text-brand-blue" id="instant-category">Length Conversion</span>
      <button id="instant-copy" class="text-xs font-semibold text-muted-text hover:text-brand-blue flex items-center gap-1 cursor-pointer bg-transparent border-0 select-none">
        Copy
      </button>
    </div>
    <div class="flex flex-col sm:flex-row items-baseline gap-2 mt-1">
      <span class="text-base font-mono text-ink font-semibold" id="instant-query">25 kg =</span>
      <span class="text-2xl font-mono text-brand-blue font-bold" id="instant-answer">55.1155 lbs</span>
    </div>
    <div class="flex items-center justify-between mt-4 pt-3 border-t border-hairline text-xs">
      <span class="text-muted-text font-mono text-[10px]" id="instant-formula">1 lb = 0.453592 kg</span>
      <a id="instant-link" href="#" class="text-brand-blue font-semibold hover:underline flex items-center gap-1 cursor-pointer select-none">
        Open Converter
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </div>
</div>

<script>
  import { parseSearchQuery, getFormulaExplanation, categories, UNIT_SYNONYMS } from '../lib/conversions';

  const searchInput = document.getElementById('global-search') as HTMLInputElement;
  const clearBtn = document.getElementById('search-clear') as HTMLButtonElement;
  const instantResult = document.getElementById('instant-result') as HTMLDivElement;
  
  const instantCategory = document.getElementById('instant-category') as HTMLSpanElement;
  const instantQuery = document.getElementById('instant-query') as HTMLSpanElement;
  const instantAnswer = document.getElementById('instant-answer') as HTMLSpanElement;
  const instantFormula = document.getElementById('instant-formula') as HTMLSpanElement;
  const instantLink = document.getElementById('instant-link') as HTMLAnchorElement;
  const instantCopy = document.getElementById('instant-copy') as HTMLButtonElement;

  let lastCopiedValue = '';

  const specialistToolsList = [
    // Cooking & Baking
    { keys: ["flour cups to grams", "flour cups", "cups to grams flour"], href: "/cups-to-grams-flour" },
    { keys: ["butter cups to grams", "butter cups", "cups to grams butter"], href: "/cups-to-grams-butter" },
    { keys: ["sugar cups to grams", "sugar cups", "cups to grams sugar"], href: "/cups-to-grams-sugar" },
    { keys: ["rice cups to grams", "rice cups", "cups to grams rice"], href: "/cups-to-grams-rice" },
    { keys: ["honey cups to grams", "honey cups", "cups to grams honey"], href: "/cups-to-grams-honey" },
    { keys: ["milk cups to grams", "milk cups", "cups to grams milk"], href: "/cups-to-grams-milk" },
    { keys: ["oats cups to grams", "oats cups", "cups to grams oats"], href: "/cups-to-grams-oats" },
    { keys: ["recipe scale calc", "recipe scale calculator", "recipe scaler", "scale recipe"], href: "/recipe-scale-calculator" },
    { keys: ["baking chart", "baking conversion chart"], href: "/baking-conversion-chart" },
    { keys: ["oven temp", "oven temperature", "oven temperature converter"], href: "/oven-temperature-converter-c-to-f" },
    { keys: ["fan oven converter", "fan oven"], href: "/fan-oven-temperature-converter" },
    { keys: ["gas mark to c/f", "gas mark", "gas mark converter"], href: "/gas-mark-to-celsius-to-fahrenheit" },
    { keys: ["candy stage temp", "candy temperature", "candy stage"], href: "/candy-making-temperature-stages-chart" },
    { keys: ["meat internal temp", "meat temperature", "meat cooking temperature"], href: "/meat-internal-temperature-guide-c-to-f" },
    { keys: ["bread proof temp", "bread proofing", "dough proofing"], href: "/proof-temperature-for-bread-c-to-f" },

    // Engineering & Trade
    { keys: ["awg wire to mm2", "awg to mm2", "wire gauge calculator", "awg wire gauge"], href: "/awg-to-mm2-wire-gauge-calculator" },
    { keys: ["mm2 to awg wire", "mm2 to awg", "mm to awg"], href: "/mm2-to-awg-calculator" },
    { keys: ["torque ft-lb to nm", "torque converter", "ft-lb to nm", "nm to ft-lb"], href: "/torque-converter-ft-lb-to-nm" },
    { keys: ["bolt torque specs", "bolt torque", "torque specs"], href: "/bolt-torque-spec-calculator" },
    { keys: ["pipe size", "pipe size nom/actual", "nominal pipe size", "pipe size converter"], href: "/pipe-size-converter-nominal-to-actual" },
    { keys: ["hardness converter", "rockwell brinell vickers", "hrc to hv", "hardness"], href: "/hardness-converter-rockwell-brinell-vickers" },
    { keys: ["steel weight calc", "steel weight calculator", "steel weight"], href: "/steel-weight-calculator-kg-per-meter" },
    { keys: ["thread pitch", "thread pitch metric/un", "unc unf converter"], href: "/thread-pitch-converter-metric-unc-unf" },
    { keys: ["psi/bar/kpa", "psi to bar", "bar to kpa", "psi to kpa"], href: "/psi-to-bar-to-kpa-converter" },
    { keys: ["flow gpm to lpm", "flow rate converter", "gpm to lpm", "lpm to gpm"], href: "/flow-rate-converter-gpm-to-lpm" },

    // Scientific & Lab
    { keys: ["molarity calculator", "molarity", "moles calculator"], href: "/molarity-calculator" },
    { keys: ["concentration ppm/mgl", "ppm to mgl", "ppm to mg/l", "concentration converter"], href: "/concentration-converter-ppm-to-mgL" },
    { keys: ["ph to h+ concentration", "ph to h+", "ph calculator", "hydrogen concentration"], href: "/ph-to-hydrogen-concentration-calculator" },
    { keys: ["absorbance/transmittance", "absorbance to transmittance", "transmittance to absorbance"], href: "/spectrophotometry-absorbance-to-transmittance" },
    { keys: ["osmolality/osmolarity", "osmolality to osmolarity"], href: "/osmolality-to-osmolarity-converter" },
    { keys: ["brix to specific gravity", "brix to sg", "brix converter"], href: "/brix-to-specific-gravity-calculator" },
    { keys: ["abv to proof", "abv to proof converter", "alcohol proof"], href: "/proof-to-abv-alcohol-converter" },
    { keys: ["specific gravity calc", "specific gravity", "sg calculator"], href: "/specific-gravity-calculator" },

    // Construction & DIY
    { keys: ["board feet calculator", "board feet", "lumber board feet"], href: "/board-feet-calculator" },
    { keys: ["square footage calc", "square footage", "sq ft calculator", "square feet"], href: "/square-footage-calculator" },
    { keys: ["mulch coverage", "mulch calculator", "mulch coverage calc"], href: "/mulch-coverage-calculator" },
    { keys: ["paint coverage", "paint calculator", "paint coverage calc"], href: "/paint-coverage-calculator-sq-ft-per-gallon" },
    { keys: ["concrete bags volume", "concrete bags", "concrete calculator"], href: "/concrete-volume-calculator-bags-to-cubic-feet" },
    { keys: ["gravel weight", "gravel calculator", "tons to cubic yards"], href: "/gravel-weight-calculator-tons-to-cubic-yards" },
    { keys: ["lumber linear/board ft", "linear feet to board feet", "lumber calculator"], href: "/lumber-linear-feet-to-board-feet" },
    { keys: ["roofing square", "roofing calculator", "roof squares"], href: "/roofing-square-calculator" },
    { keys: ["tile coverage", "tile calculator", "tiles calculator"], href: "/tile-coverage-calculator" },
    { keys: ["concrete mix ratios", "concrete mix", "concrete ratio"], href: "/concrete-mix-ratio-calculator" },
    { keys: ["rebar weight", "rebar calculator", "rebar weight calc"], href: "/rebar-weight-calculator" },

    // Sizing & Automotive
    { keys: ["shoe size us/eu/uk", "shoe size converter", "shoe size"], href: "/shoe-size-converter-us-to-eu" },
    { keys: ["dress size us/uk/eu", "dress size converter", "dress size"], href: "/dress-size-converter-us-to-uk" },
    { keys: ["ring size us/uk/eu", "ring size converter", "ring size"], href: "/ring-size-converter-us-to-uk" },
    { keys: ["tire size speedometer", "tire size calculator", "speedometer error"], href: "/tire-size-calculator" },
    { keys: ["feet & inches to cm", "feet to cm", "inches to cm", "height converter"], href: "/feet-and-inches-to-cm" },
    { keys: ["pounds & ounces to kg", "lbs to kg", "ounces to kg"], href: "/pounds-and-ounces-to-kg" },
    { keys: ["hours/mins to seconds", "time to seconds", "minutes to seconds"], href: "/hours-minutes-seconds-to-seconds" },

    // Finance & Business
    { keys: ["simple interest", "simple interest calculator", "interest calculator"], href: "/simple-interest-calculator" },
    { keys: ["compound interest", "compound interest calculator", "compound interest calc"], href: "/compound-interest-calculator" },
    { keys: ["sales tax", "sales tax calculator", "tax calculator"], href: "/sales-tax-calculator" },
    { keys: ["discount calculator", "discount", "savings calculator"], href: "/discount-calculator" },
    { keys: ["salary to hourly", "hourly to salary", "wage calculator"], href: "/salary-to-hourly-calculator" },
  ];

  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const val = searchInput.value.trim();
      if (!val) return;

      const cleaned = val.toLowerCase();
      const withoutPrefix = cleaned.replace(/^(convert|what is|how many|show me|find)\s+/i, "").trim();

      // Check specialist tools list for keyword match
      const matchedTool = specialistToolsList.find(t => 
        t.keys.some(k => k === withoutPrefix || withoutPrefix.includes(k) || k.includes(withoutPrefix))
      );
      if (matchedTool) {
        e.preventDefault();
        window.location.href = matchedTool.href;
        return;
      }

      // 1. Try parsing with a numeric value (e.g. "25 kg to lbs")
      const parsed = parseSearchQuery(val);
      if (parsed) {
        e.preventDefault();
        window.location.href = `/${parsed.fromUnit.id}-to-${parsed.toUnit.id}?v=${parsed.value}`;
        return;
      }

      // 2. Try parsing a pair without value (e.g. "kg to lbs")
      const pairRegex = /^([a-zA-Z°'"\s]+?)\s+(?:to|in|into|=|as)\s+([a-zA-Z°'"\s]+)$/i;
      const pairMatch = withoutPrefix.match(pairRegex);
      if (pairMatch) {
        const fromRaw = pairMatch[1].trim();
        const toRaw = pairMatch[2].trim();
        
        const fromResolved = UNIT_SYNONYMS[fromRaw] || UNIT_SYNONYMS[fromRaw.replace(/s$/, "")];
        const toResolved = UNIT_SYNONYMS[toRaw] || UNIT_SYNONYMS[toRaw.replace(/s$/, "")];
        
        if (fromResolved && toResolved && fromResolved.categoryId === toResolved.categoryId) {
          e.preventDefault();
          window.location.href = `/${fromResolved.unitId}-to-${toResolved.unitId}`;
          return;
        }
      }

      // 3. Try matching a single unit name/symbol (e.g. "kg", "kilogram", "guntha")
      const singleUnitResolved = UNIT_SYNONYMS[withoutPrefix] || UNIT_SYNONYMS[withoutPrefix.replace(/s$/, "")];
      if (singleUnitResolved) {
        e.preventDefault();
        window.location.href = `/${singleUnitResolved.categoryId}-converter`;
        return;
      }

      // 4. Try matching a category name or id directly (e.g. "length", "area")
      const matchedCategory = categories.find(cat => 
        cat.id.toLowerCase() === withoutPrefix || 
        cat.name.toLowerCase() === withoutPrefix
      );
      if (matchedCategory) {
        e.preventDefault();
        window.location.href = `/${matchedCategory.id}-converter`;
        return;
      }
    }
  });

  searchInput?.addEventListener('input', () => {
    const val = searchInput.value;
    if (val.trim()) {
      clearBtn?.classList.remove('hidden');
    } else {
      clearBtn?.classList.add('hidden');
    }

    // Try parsing the query in real-time
    const parsed = parseSearchQuery(val);
    if (parsed) {
      // Show instant converter card
      if (instantCategory) instantCategory.textContent = `${parsed.category.name} Conversion`;
      if (instantQuery) instantQuery.textContent = `${parsed.value} ${parsed.fromUnit.symbol} =`;
      
      const formatResult = (v: number) => {
        if (v === 0) return '0';
        const absV = Math.abs(v);
        if (absV < 1e-6 || absV > 1e12) return v.toExponential(6);
        return Number(v.toFixed(9)).toString();
      };
      
      const formattedAns = `${formatResult(parsed.result)} ${parsed.toUnit.symbol}`;
      if (instantAnswer) instantAnswer.textContent = formattedAns;
      lastCopiedValue = formatResult(parsed.result);
      
      if (instantFormula) {
        instantFormula.textContent = getFormulaExplanation(parsed.fromUnit.id, parsed.toUnit.id, parsed.category.id);
      }
      if (instantLink) {
        instantLink.href = `/${parsed.fromUnit.id}-to-${parsed.toUnit.id}?v=${parsed.value}`;
      }
      
      instantResult?.classList.remove('hidden');
    } else {
      instantResult?.classList.add('hidden');
    }

    // Filter cards
    const categoryCards = document.querySelectorAll('[data-category-name]');
    const noResults = document.getElementById('no-results');
    const query = val.toLowerCase().trim();
    let visibleCount = 0;

    categoryCards.forEach(card => {
      if (parsed) {
        // Keep all categories visible if it's an active calculation
        (card as HTMLElement).style.display = '';
        visibleCount++;
        return;
      }
      
      const name = card.getAttribute('data-category-name')?.toLowerCase() || '';
      const desc = card.getAttribute('data-category-desc')?.toLowerCase() || '';
      const match = !query || name.includes(query) || desc.includes(query);
      (card as HTMLElement).style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });

    if (noResults) {
      noResults.classList.toggle('hidden', visibleCount > 0);
    }
  });

  clearBtn?.addEventListener('click', () => {
    searchInput.value = '';
    clearBtn.classList.add('hidden');
    if (instantResult) instantResult.classList.add('hidden');
    searchInput.focus();

    const categoryCards = document.querySelectorAll('[data-category-name]');
    const noResults = document.getElementById('no-results');
    categoryCards.forEach(card => {
      (card as HTMLElement).style.display = '';
    });
    if (noResults) noResults.classList.add('hidden');
  });

  instantCopy?.addEventListener('click', () => {
    if (lastCopiedValue) {
      navigator.clipboard.writeText(lastCopiedValue).then(() => {
        const originalText = instantCopy.textContent;
        instantCopy.textContent = 'Copied!';
        instantCopy.style.color = '#0070f3';
        setTimeout(() => {
          instantCopy.textContent = originalText;
          instantCopy.style.color = '';
        }, 1500);
      });
    }
  });
</script>
