---
import ThemeToggle from '../components/ThemeToggle.astro';
import { languages } from '../lib/translations';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  categorySlug?: string;
}

const { title, description, canonical, categorySlug } = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site || 'https://myunitconverter.app').href;
---
<!DOCTYPE html>
<html lang="en" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="Unit Convert" />
  <link rel="manifest" href="/site.webmanifest" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Theme and Language init: prevent flash of wrong styling -->
  <script is:inline>
    const theme = localStorage.getItem('theme') || 
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    document.documentElement.classList.toggle('dark', theme === 'dark');

    const lang = localStorage.getItem('lang') || 'en';
    document.documentElement.setAttribute('lang', lang);
  </script>
</head>
<body class="min-h-screen flex flex-col antialiased">
  
  <!-- NAV -->
  <nav class="border-b border-hairline sticky top-0 bg-canvas/80 backdrop-blur-md z-50 transition-colors duration-200">
    <div class="max-w-[1100px] mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/" class="font-semibold text-base tracking-tight hover:opacity-90 transition-opacity flex items-center gap-1.5">
        <svg class="w-4 h-4 text-ink fill-current" viewBox="0 0 75 65" fill="none"><path d="M37.5 0L75 65H0L37.5 0Z" fill="currentColor"/></svg>
        <span>my<span class="text-brand-blue font-bold">unit</span>converter</span>
      </a>
      
      <div class="flex items-center gap-3">
        <select
          id="lang-select"
          class="bg-canvas border border-hairline text-ink rounded-md px-1.5 py-1 text-xs cursor-pointer focus:outline-none focus:ring-1 focus:ring-brand-blue font-medium transition-all"
          aria-label="Select Language"
        >
          {Object.entries(languages).map(([code, name]) => (
            <option value={code}>{name}</option>
          ))}
        </select>
        <ThemeToggle />
      </div>
    </div>
  </nav>

  <!-- MAIN CONTENT CONTAINER -->
  <div class="relative flex-1 flex flex-col z-10">
    <!-- Plain background, no mesh gradient -->
    
    <main class="flex-1 w-full max-w-[1100px] mx-auto px-4 relative z-10">
      <slot />
    </main>
  </div>

  <!-- FOOTER -->
  <footer class="border-t border-hairline bg-card mt-20 py-8 relative z-10 transition-colors duration-200">
    <div class="max-w-[1100px] mx-auto px-4 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-muted-text">
      <p class="flex items-center gap-1.5 flex-wrap">
        <span>© {new Date().getFullYear()}</span>
        <svg class="w-3.5 h-3.5 text-muted-text fill-current" viewBox="0 0 75 65" fill="none"><path d="M37.5 0L75 65H0L37.5 0Z" fill="currentColor"/></svg>
        <span>myunitconverter.app — Fast, free, and open source.</span>
      </p>
      <div class="flex gap-6 font-medium">
        <a href="/about" class="hover:text-brand-blue transition-colors">About</a>
        <a href="/privacy" class="hover:text-brand-blue transition-colors">Privacy</a>
        <a href="/contact" class="hover:text-brand-blue transition-colors">Contact</a>
      </div>
    </div>
  </footer>

  <script>
    import { translations, type LanguageCode } from '../lib/translations';

    function translatePage(lang: LanguageCode) {
      const dict = translations[lang] || translations.en;
      document.querySelectorAll('[data-t]').forEach(el => {
        const key = el.getAttribute('data-t') as keyof typeof dict;
        if (key && dict[key]) {
          if (el.tagName === 'INPUT' && el.hasAttribute('placeholder')) {
            el.setAttribute('placeholder', dict[key]);
          } else {
            el.textContent = dict[key];
          }
        }
      });
      document.documentElement.setAttribute('lang', lang);
    }

    const select = document.getElementById('lang-select') as HTMLSelectElement | null;
    if (select) {
      const savedLang = localStorage.getItem('lang') || 'en';
      select.value = savedLang;
      translatePage(savedLang as LanguageCode);

      select.addEventListener('change', (e) => {
        const val = (e.target as HTMLSelectElement).value as LanguageCode;
        localStorage.setItem('lang', val);
        translatePage(val);
        window.dispatchEvent(new CustomEvent('lang-change', { detail: val }));
      });
    }

    window.addEventListener('lang-change', (e: any) => {
      if (select && select.value !== e.detail) {
        select.value = e.detail;
        translatePage(e.detail);
      }
    });
  </script>
</body>
</html>
